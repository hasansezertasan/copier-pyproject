#!/usr/bin/env python3
"""
Profiling script for {{github_repo_name}}.

This script provides examples for profiling your application using py-spy, scalene, and cProfile.

Usage:
    python profile.py [tool] [script]

Tools:
    py-spy: Sampling profiler (low overhead)
    scalene: CPU/memory/line profiler
    cprofile: Built-in profiler with visualization

Examples:
    # Profile with py-spy (run in another terminal)
    py-spy top -- python profile.py run

    # Profile with scalene
    python profile.py scalene

    # Profile with cProfile
    python profile.py cprofile

    # Run the app normally
    python profile.py run
"""

import sys
import subprocess
from pathlib import Path

# Import the main module
import {{github_repo_name}}

def run_app():
    """Run the main application for profiling."""
    {% if include_cli %}
    from {{github_repo_name}}.cli.app import app
    app()
    {% elif include_web %}
    from {{github_repo_name}}.web.app import main
    main()
    {% elif include_tui %}
    from {{github_repo_name}}.tui.app import main
    main()
    {% else %}
    print("No main entry point found. Please modify profile.py to run your app.")
    {% endif %}

def profile_pyspy():
    """Profile with py-spy."""
    print("Run this in another terminal:")
    print(f"py-spy top -- python {__file__} run")
    print("Then press Ctrl+C to stop profiling.")

def profile_scalene():
    """Profile with scalene."""
    cmd = [sys.executable, "-m", "scalene", "--cpu", "--memory", __file__, "run"]
    try:
        result = subprocess.run(cmd, check=False)
        if result.returncode != 0:
            print(f"Error: scalene exited with code {result.returncode}", file=sys.stderr)
            print("Make sure scalene is installed: pip install scalene", file=sys.stderr)
            sys.exit(result.returncode)
    except FileNotFoundError:
        print("Error: scalene module not found.", file=sys.stderr)
        print("Install it with: pip install scalene", file=sys.stderr)
        sys.exit(1)
    except subprocess.SubprocessError as e:
        print(f"Error running scalene: {e}", file=sys.stderr)
        sys.exit(1)

def profile_cprofile():
    """Profile with cProfile and visualize with snakeviz."""
    import cProfile

    profile_file = "profile.prof"
    profiler = cProfile.Profile()

    try:
        profiler.enable()
        run_app()
        profiler.disable()
    except Exception as e:
        profiler.disable()
        print(f"Error during profiling: {e}", file=sys.stderr)
        raise

    try:
        profiler.dump_stats(profile_file)
        print(f"Profile saved to {profile_file}")
        print("To visualize:")
        print(f"snakeviz {profile_file}")
        print("Or view in browser with:")
        print(f"python -m pstats {profile_file}")
    except (OSError, IOError) as e:
        print(f"Error: Failed to write profile to {profile_file}: {e}", file=sys.stderr)
        sys.exit(1)

def main():
    if len(sys.argv) < 2:
        print(__doc__)
        return

    tool = sys.argv[1]

    if tool == "run":
        run_app()
    elif tool == "py-spy":
        profile_pyspy()
    elif tool == "scalene":
        profile_scalene()
    elif tool == "cprofile":
        profile_cprofile()
    else:
        print(f"Unknown tool: {tool}")
        print(__doc__)

if __name__ == "__main__":
    main()
