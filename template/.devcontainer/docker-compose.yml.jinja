---
{% set redis_enabled = include_redis or (include_worker and worker_broker == 'redis') -%}
{%- set redis_image = ('valkey/valkey:8' if redis_backend == 'valkey' else 'redis:7') if include_redis else 'redis:7' -%}
{%- set redis_cli = 'valkey-cli' if (include_redis and redis_backend == 'valkey') else 'redis-cli' -%}
{%- set kafka_enabled = include_worker and worker_broker == 'kafka' -%}
{%- set nats_enabled = include_worker and worker_broker == 'nats' -%}
{%- set rabbitmq_enabled = include_worker and worker_broker == 'rabbitmq' -%}
{%- set has_healthy_deps = include_postgres or redis_enabled or kafka_enabled or nats_enabled or rabbitmq_enabled -%}
services:
  # Update this to the name of the service you want to work with in your docker-compose.yml file
  devcontainer:
    image: ghcr.io/astral-sh/uv:python3.14-bookworm-slim
    volumes:
      # Update this to wherever you want VS Code to mount the folder of your project
      - ../..:/workspaces:cached
    # Uncomment the next four lines if you will use a ptrace-based debugger like C++, Go, and Rust.
    # cap_add:
    #   - SYS_PTRACE
    # security_opt:
    #   - seccomp:unconfined

    # Overrides default command so things don't shut down after the process ends.
    command: sleep infinity
{%- if include_postgres or redis_enabled %}
    env_file:
      - path: ../.env
        required: false
{%- endif %}
{%- if include_vpn %}
    # Share the vpn service's network namespace so all devcontainer traffic
    # routes through the VPN tunnel. Port forwards must be declared on the
    # `vpn` service rather than here when this is enabled.
    network_mode: "service:vpn"
{%- endif %}
{%- if has_healthy_deps or include_vpn %}
    depends_on:
{%- if include_vpn %}
      vpn:
        condition: service_started
{%- endif %}
{%- if include_postgres %}
      postgres:
        condition: service_healthy
{%- endif %}
{%- if redis_enabled %}
      redis:
        condition: service_healthy
{%- endif %}
{%- if kafka_enabled %}
      kafka:
        condition: service_healthy
{%- endif %}
{%- if rabbitmq_enabled %}
      rabbitmq:
        condition: service_healthy
{%- endif %}
{%- if nats_enabled %}
      nats:
        condition: service_started
{%- endif %}
{%- endif %}
{%- if include_postgres %}
  postgres:
    image: postgres:17
    restart: unless-stopped
    env_file:
      - path: ../.env
        required: false
    environment:
      # Dev-only: allow password-less local connections so the container starts
      # even without a `.env`. Override POSTGRES_PASSWORD in `.env` for anything
      # resembling production. Without this the official image refuses to start
      # and the devcontainer blocks forever on `condition: service_healthy`.
      POSTGRES_HOST_AUTH_METHOD: ${POSTGRES_HOST_AUTH_METHOD:-trust}
    ports:
      - "5432:5432"
    volumes:
      - postgres-data:/var/lib/postgresql/data
    logging:
      options:
        max-size: 10m
        max-file: "3"
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ${POSTGRES_USER:-postgres}"]
      interval: 5s
      timeout: 3s
      retries: 10
{%- endif %}
{%- if redis_enabled %}
  redis:
    image: {{ redis_image }}
    restart: unless-stopped
    env_file:
      - path: ../.env
        required: false
    ports:
      - "6379:6379"
    volumes:
      - redis-data:/data
    logging:
      options:
        max-size: 10m
        max-file: "3"
    healthcheck:
      test: ["CMD", "{{ redis_cli }}", "ping"]
      interval: 5s
      timeout: 3s
      retries: 10
{%- endif %}
{%- if include_worker %}
{%- if worker_broker == "rabbitmq" %}
  rabbitmq:
    image: rabbitmq:4.0.9-management
    restart: unless-stopped
    env_file:
      - path: ../.env
        required: false
    environment:
      RABBITMQ_DEFAULT_USER: ${RABBITMQ_DEFAULT_USER:-guest}
      RABBITMQ_DEFAULT_PASS: ${RABBITMQ_DEFAULT_PASS:-guest}
    ports:
      - "5672:5672"
      - "15672:15672"
    logging:
      options:
        max-size: 10m
        max-file: "3"
    healthcheck:
      test: ["CMD", "rabbitmq-diagnostics", "-q", "ping"]
      interval: 10s
      timeout: 5s
      retries: 10
{%- endif -%}
{%- if worker_broker == "kafka" %}
  kafka:
    image: bitnami/kafka:3.9
    restart: unless-stopped
    environment:
      KAFKA_CFG_NODE_ID: 0
      KAFKA_CFG_PROCESS_ROLES: controller,broker
      KAFKA_CFG_LISTENERS: PLAINTEXT://:9092,CONTROLLER://:9093
      # Clients read this from broker metadata after bootstrap; it must be the
      # name other compose services (and the devcontainer) reach the broker by.
      # Without it Bitnami defaults to localhost:9092 and cross-container clients
      # silently fail to connect — while the localhost healthcheck still passes.
      KAFKA_CFG_ADVERTISED_LISTENERS: PLAINTEXT://kafka:9092
      KAFKA_CFG_LISTENER_SECURITY_PROTOCOL_MAP: CONTROLLER:PLAINTEXT,PLAINTEXT:PLAINTEXT
      KAFKA_CFG_CONTROLLER_QUORUM_VOTERS: 0@kafka:9093
      KAFKA_CFG_CONTROLLER_LISTENER_NAMES: CONTROLLER
    ports:
      - "9092:9092"
    logging:
      options:
        max-size: 10m
        max-file: "3"
    healthcheck:
      test: ["CMD-SHELL", "kafka-topics.sh --bootstrap-server localhost:9092 --list"]
      interval: 10s
      timeout: 10s
      retries: 15
{%- endif -%}
{%- if worker_broker == "nats" %}
  nats:
    image: nats:2.10
    restart: unless-stopped
    command: ["-js", "-m", "8222"]
    ports:
      - "4222:4222"
      - "8222:8222"
    logging:
      options:
        max-size: 10m
        max-file: "3"
{%- endif -%}
{%- endif -%}
{%- if include_pgadmin %}
  pgadmin:
    profiles:
      - tools
    image: dpage/pgadmin4:8
    restart: unless-stopped
    env_file:
      - path: ../.env
        required: false
    environment:
      PGADMIN_DEFAULT_EMAIL: ${PGADMIN_DEFAULT_EMAIL:-admin@example.com}
      PGADMIN_DEFAULT_PASSWORD: ${PGADMIN_DEFAULT_PASSWORD:-admin}
    ports:
      - "5050:80"
    depends_on:
      - postgres
{%- endif -%}
{%- if include_adminer %}
  adminer:
    profiles:
      - tools
    image: adminer:4
    restart: unless-stopped
    ports:
      - "8081:8080"
    depends_on:
      - postgres
{%- endif -%}
{%- if include_dbeaver %}
  cloudbeaver:
    profiles:
      - tools
    image: dbeaver/cloudbeaver:24
    restart: unless-stopped
    ports:
      - "8978:8978"
{%- endif -%}
{%- if include_vpn %}
  vpn:
    image: dperson/openvpn-client
    cap_add:
      - NET_ADMIN
    devices:
      - /dev/net/tun:/dev/net/tun
    environment:
      TZ: "EST5EDT"
    read_only: true
    restart: unless-stopped
    security_opt:
      - label:disable
    stdin_open: true
    tmpfs:
      - /run
      - /tmp
    tty: true
    volumes:
      - ./vpn:/vpn
{%- endif %}
{%- if include_postgres or redis_enabled %}
volumes:
{%- if include_postgres %}
  postgres-data: {}
{%- endif %}
{%- if redis_enabled %}
  redis-data: {}
{%- endif %}
{%- endif %}
