---
{%- set redis_enabled = include_redis or (include_worker and worker_broker == 'redis') -%}
{%- set redis_image = (redis_backend ~ ':latest') if include_redis else 'redis:latest' -%}
{%- set redis_cli = 'valkey-cli' if (include_redis and redis_backend == 'valkey') else 'redis-cli' -%}
{%- set has_healthy_deps = include_postgres or redis_enabled -%}
services:
  # Update this to the name of the service you want to work with in your docker-compose.yml file
  devcontainer:
    image: ghcr.io/astral-sh/uv:python3.14-bookworm-slim
    volumes:
      # Update this to wherever you want VS Code to mount the folder of your project
      - ../..:/workspaces:cached
    # Uncomment the next four lines if you will use a ptrace-based debugger like C++, Go, and Rust.
    # cap_add:
    #   - SYS_PTRACE
    # security_opt:
    #   - seccomp:unconfined

    # Overrides default command so things don't shut down after the process ends.
    command: sleep infinity
{%- if include_postgres or redis_enabled %}
    env_file:
      - ../.env
{%- endif %}
{%- if include_vpn %}
    # Share the vpn service's network namespace so all devcontainer traffic
    # routes through the VPN tunnel. Port forwards must be declared on the
    # `vpn` service rather than here when this is enabled.
    network_mode: "service:vpn"
{%- endif %}
{%- if has_healthy_deps or include_vpn %}
    depends_on:
{%- if include_vpn %}
      - vpn
{%- endif %}
{%- if include_postgres %}
      postgres:
        condition: service_healthy
{%- endif %}
{%- if redis_enabled %}
      redis:
        condition: service_healthy
{%- endif %}
{%- endif %}
{%- if include_postgres %}
  postgres:
    image: postgres:latest
    restart: unless-stopped
    env_file:
      - ../.env
    ports:
      - "5432:5432"
    volumes:
      - postgres-data:/var/lib/postgresql/data
    logging:
      options:
        max-size: 10m
        max-file: "3"
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ${POSTGRES_USER:-postgres}"]
      interval: 5s
      timeout: 3s
      retries: 10
{%- endif %}
{%- if redis_enabled %}
  redis:
    image: {{ redis_image }}
    restart: unless-stopped
    env_file:
      - ../.env
    ports:
      - "6379:6379"
    volumes:
      - redis-data:/data
    logging:
      options:
        max-size: 10m
        max-file: "3"
    healthcheck:
      test: ["CMD", "{{ redis_cli }}", "ping"]
      interval: 5s
      timeout: 3s
      retries: 10
{%- endif %}
{%- if include_worker %}
{%- if worker_broker == "rabbitmq" %}
  rabbitmq:
    image: rabbitmq:4.0.9-management
    restart: unless-stopped
    env_file:
      - ../.env
    environment:
      RABBITMQ_DEFAULT_USER: ${RABBITMQ_DEFAULT_USER:-guest}
      RABBITMQ_DEFAULT_PASS: ${RABBITMQ_DEFAULT_PASS:-guest}
    ports:
      - "5672:5672"
      - "15672:15672"
    logging:
      options:
        max-size: 10m
        max-file: "3"
{%- endif -%}
{%- if worker_broker == "kafka" %}
  kafka:
    image: bitnami/kafka:latest
    restart: unless-stopped
    environment:
      KAFKA_CFG_NODE_ID: 0
      KAFKA_CFG_PROCESS_ROLES: controller,broker
      KAFKA_CFG_LISTENERS: PLAINTEXT://:9092,CONTROLLER://:9093
      KAFKA_CFG_LISTENER_SECURITY_PROTOCOL_MAP: CONTROLLER:PLAINTEXT,PLAINTEXT:PLAINTEXT
      KAFKA_CFG_CONTROLLER_QUORUM_VOTERS: 0@kafka:9093
      KAFKA_CFG_CONTROLLER_LISTENER_NAMES: CONTROLLER
    ports:
      - "9092:9092"
    logging:
      options:
        max-size: 10m
        max-file: "3"
{%- endif -%}
{%- if worker_broker == "nats" %}
  nats:
    image: nats:latest
    restart: unless-stopped
    command: ["-js", "-m", "8222"]
    ports:
      - "4222:4222"
      - "8222:8222"
    logging:
      options:
        max-size: 10m
        max-file: "3"
{%- endif -%}
{%- endif -%}
{%- if include_pgadmin %}
  pgadmin:
    profiles:
      - tools
    image: dpage/pgadmin4:latest
    restart: unless-stopped
    env_file:
      - ../.env
    environment:
      PGADMIN_DEFAULT_EMAIL: ${PGADMIN_DEFAULT_EMAIL:-admin@example.com}
      PGADMIN_DEFAULT_PASSWORD: ${PGADMIN_DEFAULT_PASSWORD:-admin}
    ports:
      - "5050:80"
    depends_on:
      - postgres
{%- endif -%}
{%- if include_adminer %}
  adminer:
    profiles:
      - tools
    image: adminer:latest
    restart: unless-stopped
    ports:
      - "8081:8080"
    depends_on:
      - postgres
{%- endif -%}
{%- if include_dbeaver %}
  cloudbeaver:
    profiles:
      - tools
    image: dbeaver/cloudbeaver:latest
    restart: unless-stopped
    environment:
      - PUID=1000
      - PGID=1000
      - TZ=Etc/UTC
    ports:
      - "8978:8978"
{%- endif -%}
{%- if include_vpn %}
  vpn:
    image: dperson/openvpn-client
    cap_add:
      - NET_ADMIN
    devices:
      - /dev/net/tun:/dev/net/tun
    environment:
      TZ: "EST5EDT"
    read_only: true
    restart: unless-stopped
    security_opt:
      - label:disable
    stdin_open: true
    tmpfs:
      - /run
      - /tmp
    tty: true
    volumes:
      - ./vpn:/vpn
{%- endif %}
{%- if include_postgres or redis_enabled %}
volumes:
{%- if include_postgres %}
  postgres-data: {}
{%- endif %}
{%- if redis_enabled %}
  redis-data: {}
{%- endif %}
{%- endif %}
