---
name: Release It
on:
  workflow_dispatch:
    inputs:
      increment:
        description: "Version increment (patch, minor, major, or an explicit version)"
        required: false
        default: ""
jobs:
  release-it:
    runs-on: ubuntu-latest
    name: Release It
    permissions:
      contents: write  # IMPORTANT: Mandatory for creating tags and GitHub Releases
    steps:
      - name: Checkout repository
        uses: actions/checkout@df4cb1c069e1874edd31b4311f1884172cec0e10  # v6
        with:
          fetch-depth: 0
      - name: Set up Node.js
        uses: actions/setup-node@49933ea5288caeca8642d1e84afbd3f7d6820020  # v4
        with:
          node-version: lts/*
      - name: Configure git
        run: |
          git config user.name "github-actions[bot]"
          git config user.email "github-actions[bot]@users.noreply.github.com"
      - name: Run release-it
        # release-it tags the release and publishes a GitHub Release; cd.yml then
        # builds and publishes to PyPI on the `release: published` event.
        env:
          GITHUB_TOKEN: {% raw %}${{ secrets.GITHUB_TOKEN }}{% endraw %}
        run: npx --yes release-it {% raw %}${{ inputs.increment }}{% endraw %} --ci
