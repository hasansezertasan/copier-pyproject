---
name: "Security scan"
on:
  pull_request:
    branches: ["main"]
  push:
    branches: ["main"]
  schedule:
    # Weekly, so newly-disclosed CVEs in already-pinned dependencies are caught
    # between code changes (Renovate bumps them, this proves the current pin is
    # still clean). Complements the PR-diff-only dependency-review workflow.
    - cron: "17 5 * * 1"
# Least-privilege default; each job elevates only what it needs.
permissions:
  contents: read
jobs:
  gitleaks:
    name: Secret scan (gitleaks)
    runs-on: ubuntu-latest
    timeout-minutes: 10
    steps:
      - name: Checkout repository
        uses: actions/checkout@9c091bb21b7c1c1d1991bb908d89e4e9dddfe3e0  # v7
        with:
          # Full history so leaked secrets in past commits are found, not just
          # the diff. GitHub's native push protection only guards new pushes.
          fetch-depth: 0
      - name: Run gitleaks
        uses: gitleaks/gitleaks-action@e0c47f4f8be36e29cdc102c57e68cb5cbf0e8d1e  # v3.0.0
        env:
          GITHUB_TOKEN: {% raw %}${{ secrets.GITHUB_TOKEN }}{% endraw %}
          # gitleaks-action is free for personal accounts and public repos. If you
          # move this repo under a GitHub *organization*, add a GITLEAKS_LICENSE
          # repository/org secret (https://gitleaks.io) — it is wired through
          # below, but stays empty (and unused) for personal/public repos.
          GITLEAKS_LICENSE: {% raw %}${{ secrets.GITLEAKS_LICENSE }}{% endraw %}
  pip-audit:
    name: Dependency audit (pip-audit)
    runs-on: ubuntu-latest
    timeout-minutes: 10
    steps:
      - name: Checkout repository
        uses: actions/checkout@9c091bb21b7c1c1d1991bb908d89e4e9dddfe3e0  # v7
      - name: Set up Python
        uses: actions/setup-python@a309ff8b426b58ec0e2a45f0f869d46889d02405  # v6.2.0
        with:
          python-version-file: .python-version
      - name: Setup uv
        uses: astral-sh/setup-uv@fac544c07dec837d0ccb6301d7b5580bf5edae39  # v8.2.0
        with:
          enable-cache: true
          cache-dependency-glob: |
            pyproject.toml
            uv.lock
      - name: Export locked runtime dependencies
        # Audit what ships: resolved deps for every optional extra (--all-extras;
        # this project keeps its dependencies under extras, so without it the
        # export is empty), excluding dev tooling and the project itself.
        # --no-hashes keeps pip-audit's resolver from demanding a hash for every
        # transitive pin.
        run: uv export --frozen --all-extras --no-dev --no-emit-project --no-hashes --format requirements.txt --output-file requirements-audit.txt
      - name: Audit dependencies for known vulnerabilities
        # Queries the PyPI Advisory DB for the full resolved tree; exits non-zero
        # on any finding. Runs in an ephemeral uvx env so pip-audit itself is not
        # a project dependency.
        run: uvx pip-audit --requirement requirements-audit.txt
{%- if include_web %}
  trivy-image:
    name: Container image scan (Trivy)
    runs-on: ubuntu-latest
    timeout-minutes: 15
    steps:
      - name: Checkout repository
        uses: actions/checkout@9c091bb21b7c1c1d1991bb908d89e4e9dddfe3e0  # v7
      - name: Build the image
        # Build the same Dockerfile that release-please.yml publishes, so the
        # scan reflects what actually ships. Tagged locally; never pushed.
        run: docker build -t {{github_repo_name}}:scan .
      - name: Scan the image
        uses: aquasecurity/trivy-action@ed142fd0673e97e23eac54620cfb913e5ce36c25  # v0.36.0
        with:
          image-ref: {{github_repo_name}}:scan
          format: table
          # Fail the job on actionable findings only.
          exit-code: "1"
          # Skip vulns with no upstream fix — they are not actionable here and
          # only add noise.
          ignore-unfixed: true
          severity: CRITICAL,HIGH
          vuln-type: os,library
{%- endif %}
