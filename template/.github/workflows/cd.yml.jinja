---
name: CD
on:
  workflow_dispatch:
  release:
    types: [published]
jobs:
  build:
    runs-on: ubuntu-latest
    name: Build the Package
    steps:
      - name: Checkout repository
        uses: actions/checkout@v6
        with:
          fetch-depth: 0
      - name: Set up Python
        uses: actions/setup-python@v6.1.0
        with:
          python-version-file: .python-version
      - name: Setup uv
        id: setup-uv
        uses: astral-sh/setup-uv@v7.1.0
        with:
          enable-cache: true
      - name: Restore cache
        if: steps.setup-uv.outputs.cache-hit == 'true'
        run: echo "Cache was restored"
      - name: Build the Package
        run: uv build --no-sources --quiet
      - name: Upload package
        uses: actions/upload-artifact@v4
        with:
          name: package-distributions
          path: dist/
  pypi-publish:
    runs-on: ubuntu-latest
    name: Publish to PyPI
    needs: build
    permissions:
      id-token: write  # IMPORTANT: Mandatory for Trusted Publishing (gh-action-pypi-publish)
    # Specifying a GitHub environment is optional, but strongly encouraged
    environment:
      name: publish
      url: https://pypi.org/project/{{github_repo_name}}/{% raw %}${{ github.ref_name }}
    steps:
    - name: Download package
      uses: actions/download-artifact@v4
      with:
        name: package-distributions
        path: dist/
    - name: Publish distribution 📦 to PyPI
      uses: pypa/gh-action-pypi-publish@release/v1
{% endraw %}
{% if include_pycrucible %}
  build-executables:
    name: Build Executables
    needs: build
    strategy:
      matrix:
        os: [ubuntu-latest, windows-latest, macos-latest]
    runs-on: {% raw %}${{ matrix.os }}{% endraw %}
    steps:
      - uses: actions/checkout@v4
      - name: Build with PyCrucible
        uses: razorblade23/pycrucible-action@v1
        with:
          source: '.'
          output: './dist/{{github_repo_name}}'
      - name: Upload executable
        uses: actions/upload-artifact@v4
        with:
          name: {{github_repo_name}}-executable-{% raw %}${{ matrix.os }}{% endraw %}
          path: ./dist/
{% endif %}
{% if include_web %}
  docker-publish:
    name: Publish Docker Image
    needs: build
    runs-on: ubuntu-latest
    permissions:
      contents: read
      packages: write
    env:
      REGISTRY: docker.io
      IMAGE_NAME: {% raw %}${{ github.repository }}{% endraw %}
    steps:
      - name: Checkout repository
        uses: actions/checkout@v4
      - name: Set up QEMU
        uses: docker/setup-qemu-action@v3
      - name: Set up Docker Buildx
        uses: docker/setup-buildx-action@v3
      - name: Log in to Docker Hub
        uses: docker/login-action@v3
        with:
          username: {% raw %}${{ secrets.DOCKERHUB_USERNAME }}{% endraw %}
          password: {% raw %}${{ secrets.DOCKERHUB_TOKEN }}{% endraw %}
      - name: Extract metadata (tags, labels)
        id: meta
        uses: docker/metadata-action@v5
        with:
          images: {% raw %}${{ env.REGISTRY }}/${{ env.IMAGE_NAME }}{% endraw %}
          tags: |
            type=semver,pattern={{"{{"}}version{{"}}"}}
            type=semver,pattern={{"{{"}}major{{"}}"}}.{{"{{"}}minor{{"}}"}}
            type=semver,pattern={{"{{"}}major{{"}}"}}
            type=raw,value=latest,enable={{"{{"}}is_default_branch{{"}}"}}
            type=sha,prefix=
      - name: Build and push Docker image
        uses: docker/build-push-action@v6
        with:
          context: .
          platforms: linux/amd64,linux/arm64
          push: true
          tags: {% raw %}${{ steps.meta.outputs.tags }}{% endraw %}
          labels: {% raw %}${{ steps.meta.outputs.labels }}{% endraw %}
          cache-from: type=gha
          cache-to: type=gha,mode=max
{% endif %}
  attach-github-release:
    runs-on: ubuntu-latest
    name: Attach Build Artifacts to GitHub Release
    needs: {% if include_pycrucible %}[pypi-publish, build-executables]{% else %}pypi-publish{% endif %}
    permissions:
      contents: write  # IMPORTANT: Mandatory for GitHub Release
    steps:
    - name: Download package
      uses: actions/download-artifact@v4
      with:
        name: package-distributions
        path: dist/
{% if include_pycrucible %}
    - name: Download executables
      uses: actions/download-artifact@v4
      with:
        pattern: {{github_repo_name}}-executable-*
        path: dist/executables/
        merge-multiple: true
{% endif %}
{% raw %}
    - name: Attach Build Artifacts to GitHub Release
      env:
        GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
      run: gh release upload ${{ github.ref_name }} ./dist/* --clobber
{% endraw %}
