---
name: Release
on:
  workflow_dispatch:
  push:
    branches:
      - main
permissions: {}
jobs:
  release-please:
    runs-on: ubuntu-latest
    name: Release Please
    permissions:
      contents: write
      issues: write  # IMPORTANT: release-please manages PR labels via the Issues API
      pull-requests: write
    outputs:
      release_created: {% raw %}${{ steps.release.outputs.release_created }}{% endraw %}
      tag_name: {% raw %}${{ steps.release.outputs.tag_name }}{% endraw %}
      version: {% raw %}${{ steps.release.outputs.version }}{% endraw %}
    steps:
      - name: Release Please
        id: release
        uses: googleapis/release-please-action@45996ed1f6d02564a971a2fa1b5860e934307cf7  # v5.0.0
        with:
          config-file: .github/release-please-config.json
          manifest-file: .github/release-please-manifest.json
  build:
    needs: release-please
    if: {% raw %}${{ needs.release-please.outputs.release_created == 'true' }}{% endraw %}
    permissions:
      contents: read  # IMPORTANT: actions/checkout needs read access to the repo
{%- if include_c_extensions %}
    name: Build the Package on {% raw %}${{ matrix.os }}{% endraw %}
    runs-on: {% raw %}${{ matrix.os }}{% endraw %}
    strategy:
      fail-fast: false
      matrix:
        os: [ubuntu-latest, windows-latest, macos-latest]
{%- else %}
    runs-on: ubuntu-latest
    name: Build the Package
{%- endif %}
    steps:
      - name: Checkout repository
        uses: actions/checkout@9c091bb21b7c1c1d1991bb908d89e4e9dddfe3e0  # v7
        with:
          # hatch-vcs derives the version from the git tag, so fetch full history
          # and tags. `force-tag-creation` in the release-please config makes
          # release-please create the tag immediately — GitHub otherwise withholds
          # a draft release's tag until it is published, which would make hatch-vcs
          # stamp the previous version.
          fetch-depth: 0
      - name: Set up Python
        uses: actions/setup-python@a309ff8b426b58ec0e2a45f0f869d46889d02405  # v6.2.0
        with:
          python-version-file: .python-version
      - name: Setup uv
        id: setup-uv
        uses: astral-sh/setup-uv@fac544c07dec837d0ccb6301d7b5580bf5edae39  # v8.2.0
        with:
          enable-cache: true
          cache-dependency-glob: |
            pyproject.toml
            uv.lock
      - name: Restore cache
        if: steps.setup-uv.outputs.cache-hit == 'true'
        run: echo "Cache was restored"
{%- if include_c_extensions %}
      - name: Build the wheel
        run: uv build --wheel --no-sources --quiet
      - name: Build the source distribution
        if: {% raw %}${{ matrix.os == 'ubuntu-latest' }}{% endraw %}
        run: uv build --sdist --no-sources --quiet
      - name: Upload package
        uses: actions/upload-artifact@ea165f8d65b6e75b540449e92b4886f43607fa02  # v4
        with:
          name: package-distributions-{% raw %}${{ matrix.os }}{% endraw %}
          path: dist/
{%- else %}
      - name: Build the Package
        run: uv build --no-sources --quiet
      - name: Upload package
        uses: actions/upload-artifact@ea165f8d65b6e75b540449e92b4886f43607fa02  # v4
        with:
          name: package-distributions
          path: dist/
{%- endif %}
  pypi-publish:
    runs-on: ubuntu-latest
    name: Publish to PyPI
    {#- Publishing to PyPI is irreversible, so it must not race ahead of the
        Docker Hub credentials preflight: gate it on the same check that gates
        docker-publish, or a half-configured secret pair would still let the
        package publish and then strand the release half-finished. #}
    needs: [release-please, build{% if include_web %}, docker-publish-preflight{% endif %}]
    if: {% raw %}${{ needs.release-please.outputs.release_created == 'true' }}{% endraw %}
    permissions:
      id-token: write  # IMPORTANT: Mandatory for Trusted Publishing (gh-action-pypi-publish)
    # Specifying a GitHub environment is optional, but strongly encouraged
    environment:
      name: publish
      url: https://pypi.org/project/{{github_repo_name}}/{% raw %}${{ needs.release-please.outputs.version }}{% endraw %}
    steps:
      - name: Download package
        uses: actions/download-artifact@d3f86a106a0bac45b974a628896c90dbdf5c8093  # v4
        with:
{%- if include_c_extensions %}
          pattern: package-distributions-*
          path: dist/
          merge-multiple: true
{%- else %}
          name: package-distributions
          path: dist/
{%- endif %}
      - name: Publish distribution to PyPI
        uses: pypa/gh-action-pypi-publish@cef221092ed1bacb1cc03d23a2d87d1d172e277b  # release/v1
{%- if include_launcher %}
  build-launcher:
    name: Build Launcher (PyCrucible)
    needs: [release-please, build]
    if: {% raw %}${{ needs.release-please.outputs.release_created == 'true' }}{% endraw %}
    permissions:
      contents: read  # IMPORTANT: actions/checkout needs read access to the repo
    strategy:
      fail-fast: false
      matrix:
        # label makes each binary's filename unique per OS (and per tool across
        # jobs), so download-artifact's merge-multiple and the release asset names
        # never collide. PyCrucible names via output:/`-o` + a `*` upload glob, so
        # no per-OS `ext` is needed here (unlike the freezer's post-build mv).
        # See ADR-007.
        include:
          - os: ubuntu-latest
            label: linux
          - os: windows-latest
            label: windows
          - os: macos-latest
            label: macos
    runs-on: {% raw %}${{ matrix.os }}{% endraw %}
    steps:
      - uses: actions/checkout@9c091bb21b7c1c1d1991bb908d89e4e9dddfe3e0  # v7
        with:
          # PyCrucible embeds the source tree; hatch-vcs needs full history + tags
          # to stamp the correct version into the embedded project (mirrors `build`).
          fetch-depth: 0
      - name: Build with PyCrucible
        uses: razorblade23/pycrucible-action@4a9aeaf7ed124775839031963dcd5295e67ac5f6  # v1.0.5
        with:
          source: '.'
          output: './dist/{{github_repo_name}}-launcher-{% raw %}${{ matrix.label }}{% endraw %}'
      - name: Upload executable
        uses: actions/upload-artifact@ea165f8d65b6e75b540449e92b4886f43607fa02  # v4
        with:
          name: {{github_repo_name}}-executable-launcher-{% raw %}${{ matrix.os }}{% endraw %}
          # Glob so the upload succeeds whether or not the tool added an extension.
          path: './dist/{{github_repo_name}}-launcher-{% raw %}${{ matrix.label }}{% endraw %}*'
{%- endif %}
{%- if include_freezer %}
  build-freezer:
    name: Build Freezer (PyInstaller)
    needs: [release-please, build]
    if: {% raw %}${{ needs.release-please.outputs.release_created == 'true' }}{% endraw %}
    permissions:
      contents: read  # IMPORTANT: actions/checkout needs read access to the repo
    strategy:
      fail-fast: false
      matrix:
        # label/ext make each binary's filename unique per OS (and per tool across
        # jobs), so download-artifact's merge-multiple and the release asset names
        # never collide. See ADR-007.
        include:
          - os: ubuntu-latest
            label: linux
            ext: ""
          - os: windows-latest
            label: windows
            ext: ".exe"
          - os: macos-latest
            label: macos
            ext: ""
    runs-on: {% raw %}${{ matrix.os }}{% endraw %}
    steps:
      - name: Checkout repository
        uses: actions/checkout@9c091bb21b7c1c1d1991bb908d89e4e9dddfe3e0  # v7
        with:
          fetch-depth: 0
      - name: Set up Python
        uses: actions/setup-python@a309ff8b426b58ec0e2a45f0f869d46889d02405  # v6.2.0
        with:
          python-version-file: .python-version
      - name: Setup uv
        uses: astral-sh/setup-uv@fac544c07dec837d0ccb6301d7b5580bf5edae39  # v8.2.0
        with:
          enable-cache: true
          cache-dependency-glob: |
            pyproject.toml
            uv.lock
      - name: Build with PyInstaller
        # The spec's static name="{{github_repo_name}}" can't see the matrix, so
        # rename the built binary to a unique per-OS name afterwards (bash is used
        # for a portable mv across the Linux/macOS/Windows runners).
        shell: bash
        run: |
          uv run --locked --group tool pyinstaller {{github_repo_name}}.spec --clean --noconfirm
          mv "dist/{{github_repo_name}}{% raw %}${{ matrix.ext }}{% endraw %}" "dist/{{github_repo_name}}-freezer-{% raw %}${{ matrix.label }}${{ matrix.ext }}{% endraw %}"
      - name: Upload executable
        uses: actions/upload-artifact@ea165f8d65b6e75b540449e92b4886f43607fa02  # v4
        with:
          name: {{github_repo_name}}-executable-freezer-{% raw %}${{ matrix.os }}{% endraw %}
          path: './dist/{{github_repo_name}}-freezer-{% raw %}${{ matrix.label }}${{ matrix.ext }}{% endraw %}'
{%- endif %}
{%- if include_compiler %}
  build-compiler:
    name: Build Compiler (Nuitka)
    needs: [release-please, build]
    if: {% raw %}${{ needs.release-please.outputs.release_created == 'true' }}{% endraw %}
    permissions:
      contents: read  # IMPORTANT: actions/checkout needs read access to the repo
    strategy:
      fail-fast: false
      matrix:
        # label/ext make each binary's filename unique per OS (and per tool across
        # jobs), so download-artifact's merge-multiple and the release asset names
        # never collide. See ADR-007.
        include:
          - os: ubuntu-latest
            label: linux
            ext: ""
          - os: windows-latest
            label: windows
            ext: ".exe"
          - os: macos-latest
            label: macos
            ext: ""
    runs-on: {% raw %}${{ matrix.os }}{% endraw %}
    steps:
      - name: Checkout repository
        uses: actions/checkout@9c091bb21b7c1c1d1991bb908d89e4e9dddfe3e0  # v7
        with:
          fetch-depth: 0
      - name: Set up Python
        uses: actions/setup-python@a309ff8b426b58ec0e2a45f0f869d46889d02405  # v6.2.0
        with:
          python-version-file: .python-version
      - name: Setup uv
        uses: astral-sh/setup-uv@fac544c07dec837d0ccb6301d7b5580bf5edae39  # v8.2.0
        with:
          enable-cache: true
          cache-dependency-glob: |
            pyproject.toml
            uv.lock
      - name: Build with Nuitka
        # --output-filename gives a unique per-OS name (Nuitka otherwise emits
        # "__main__.bin"/".exe", which is neither project- nor OS-specific). For a
        # GUI app on Windows, suppress the console window with
        # --windows-console-mode=disable (mirrors the freezer's console=False); the
        # flag is Windows-only, so it is matrix-gated to avoid erroring elsewhere.
        # macOS needs no equivalent — a --onefile binary launched from Finder runs
        # without a terminal — and --macos-create-app-bundle is deliberately NOT
        # used: it emits a .app *directory*, which would break the single-file
        # verify/upload steps (and the merge-multiple release attach). See ADR-007.
        run: uv run --locked --group tool python -m nuitka --onefile --assume-yes-for-downloads --warn-implicit-exceptions --warn-unusual-code {% if include_gui %}{% raw %}${{ matrix.os == 'windows-latest' && '--windows-console-mode=disable' || '' }}{% endraw %} {% endif %}--output-filename={{github_repo_name}}-compiler-{% raw %}${{ matrix.label }}{% endraw %} --output-dir=dist src/{{github_repo_name}}/__main__.py
      - name: Upload executable
        uses: actions/upload-artifact@ea165f8d65b6e75b540449e92b4886f43607fa02  # v4
        with:
          name: {{github_repo_name}}-executable-compiler-{% raw %}${{ matrix.os }}{% endraw %}
          # Glob so the upload succeeds whether or not the tool added an extension.
          path: './dist/{{github_repo_name}}-compiler-{% raw %}${{ matrix.label }}{% endraw %}*'
{%- endif %}
{%- if include_web %}
  docker-publish-preflight:
    name: Validate Docker Hub Credentials
    needs: release-please
    if: {% raw %}${{ needs.release-please.outputs.release_created == 'true' }}{% endraw %}
    runs-on: ubuntu-latest
    permissions: {}
    env:
      # The `secrets` context is not available in `if:` conditions, so surface
      # the username through env. The token is reduced to a presence flag —
      # never expose the value job-wide.
      DOCKERHUB_USERNAME: {% raw %}${{ secrets.DOCKERHUB_USERNAME }}{% endraw %}
      DOCKERHUB_TOKEN_SET: {% raw %}${{ secrets.DOCKERHUB_TOKEN != '' }}{% endraw %}
    steps:
      # Docker Hub publishing is opt-in via the DOCKERHUB_USERNAME/-TOKEN secret
      # pair, which is all-or-nothing: half-configured means the maintainer
      # intended to publish there but it cannot work. This job gates every
      # publish job (pypi-publish and docker-publish), so an inconsistent
      # configuration blocks the whole publish fan-out up front — otherwise the
      # irreversible PyPI upload could complete while Docker Hub fails, leaving
      # a stranded half-release.
      - name: Fail on half-configured Docker Hub credentials
        if: {% raw %}${{ (env.DOCKERHUB_USERNAME != '') != (env.DOCKERHUB_TOKEN_SET == 'true') }}{% endraw %}
        run: |
          echo "::error::Docker Hub publishing is half-configured: set both the DOCKERHUB_USERNAME and DOCKERHUB_TOKEN repository secrets, or neither to publish to GHCR only."
          exit 1
      - name: Note GHCR-only publishing
        if: {% raw %}${{ env.DOCKERHUB_USERNAME == '' }}{% endraw %}
        run: echo "::notice::DOCKERHUB_USERNAME/DOCKERHUB_TOKEN secrets are not set — skipping Docker Hub, publishing to GHCR only."
  docker-publish:
    name: Publish Docker Image
    needs: [release-please, build, docker-publish-preflight]
    if: {% raw %}${{ needs.release-please.outputs.release_created == 'true' }}{% endraw %}
    runs-on: ubuntu-latest
    permissions:
      contents: read
      packages: write
    env:
      # The `secrets` context is not available in `if:` conditions, so surface
      # the username through env to gate the optional Docker Hub login.
      DOCKERHUB_USERNAME: {% raw %}${{ secrets.DOCKERHUB_USERNAME }}{% endraw %}
    steps:
      - name: Checkout repository
        uses: actions/checkout@9c091bb21b7c1c1d1991bb908d89e4e9dddfe3e0  # v7
      - name: Set up QEMU
        uses: docker/setup-qemu-action@c7c53464625b32c7a7e944ae62b3e17d2b600130  # v3
      - name: Set up Docker Buildx
        uses: docker/setup-buildx-action@8d2750c68a42422c14e847fe6c8ac0403b4cbd6f  # v3
      - name: Log in to Docker Hub
        if: {% raw %}${{ env.DOCKERHUB_USERNAME != '' }}{% endraw %}
        uses: docker/login-action@c94ce9fb468520275223c153574b00df6fe4bcc9  # v3
        with:
          username: {% raw %}${{ secrets.DOCKERHUB_USERNAME }}{% endraw %}
          password: {% raw %}${{ secrets.DOCKERHUB_TOKEN }}{% endraw %}
      - name: Log in to GitHub Container Registry
        uses: docker/login-action@c94ce9fb468520275223c153574b00df6fe4bcc9  # v3
        with:
          registry: ghcr.io
          username: {% raw %}${{ github.actor }}{% endraw %}
          password: {% raw %}${{ secrets.GITHUB_TOKEN }}{% endraw %}
      - name: Extract metadata (tags, labels)
        id: meta
        uses: docker/metadata-action@c299e40c65443455700f0fdfc63efafe5b349051  # v5
        with:
          # The Docker Hub namespace is the Docker Hub username, which need not
          # match the GitHub owner — so build the image name from the secret,
          # not from github.repository. An empty line is dropped by the action,
          # which is what makes the Docker Hub channel opt-in.
          images: |
            {% raw %}${{ env.DOCKERHUB_USERNAME != '' && format('docker.io/{0}/{1}', env.DOCKERHUB_USERNAME, github.event.repository.name) || '' }}{% endraw %}
            ghcr.io/{% raw %}${{ github.repository }}{% endraw %}
          # No tag ref is present on a push-triggered run, so feed the
          # release-please version into the semver patterns explicitly.
          tags: |
            type=semver,pattern={{"{{"}}version{{"}}"}},value={% raw %}${{ needs.release-please.outputs.tag_name }}{% endraw %}
            type=semver,pattern={{"{{"}}major{{"}}"}}.{{"{{"}}minor{{"}}"}},value={% raw %}${{ needs.release-please.outputs.tag_name }}{% endraw %}
            type=semver,pattern={{"{{"}}major{{"}}"}},value={% raw %}${{ needs.release-please.outputs.tag_name }}{% endraw %}
            type=raw,value=latest,enable={{"{{"}}is_default_branch{{"}}"}}
            type=sha,prefix=
      - name: Build and push Docker image
        uses: docker/build-push-action@10e90e3645eae34f1e60eeb005ba3a3d33f178e8  # v6
        with:
          context: .
          platforms: linux/amd64,linux/arm64
          push: true
          tags: {% raw %}${{ steps.meta.outputs.tags }}{% endraw %}
          labels: {% raw %}${{ steps.meta.outputs.labels }}{% endraw %}
          cache-from: type=gha
          cache-to: type=gha,mode=max
{%- endif %}
  attach-github-release:
    runs-on: ubuntu-latest
    name: Attach Build Artifacts to GitHub Release
    needs: [release-please, pypi-publish{% if include_launcher %}, build-launcher{% endif %}{% if include_freezer %}, build-freezer{% endif %}{% if include_compiler %}, build-compiler{% endif %}]
    if: {% raw %}${{ needs.release-please.outputs.release_created == 'true' }}{% endraw %}
    permissions:
      contents: write  # IMPORTANT: Mandatory for GitHub Release
    steps:
      - name: Download package
        uses: actions/download-artifact@d3f86a106a0bac45b974a628896c90dbdf5c8093  # v4
        with:
{%- if include_c_extensions %}
          pattern: package-distributions-*
          path: dist/
          merge-multiple: true
{%- else %}
          name: package-distributions
          path: dist/
{%- endif %}
{%- if include_launcher or include_freezer or include_compiler %}
      - name: Download executables
        uses: actions/download-artifact@d3f86a106a0bac45b974a628896c90dbdf5c8093  # v4
        with:
          pattern: {{github_repo_name}}-executable-*
          path: dist/executables/
          merge-multiple: true
{%- endif %}
      - name: Attach Build Artifacts to the draft release
        env:
          GITHUB_TOKEN: {% raw %}${{ secrets.GITHUB_TOKEN }}{% endraw %}
        shell: bash
        run: |
          # Upload every file under dist/ (executables land in dist/executables/, so a
          # plain ./dist/* glob would pass that subdirectory to gh, which rejects dirs).
          # Guard the empty case first: `xargs` with no input never invokes gh and
          # exits 0, which would silently publish a release with zero assets attached.
          test "$(find dist -type f | wc -l)" -gt 0 \
            || { echo "::error::no artifacts found under dist/ to attach to the release"; exit 1; }
          find dist -type f -print0 | xargs -0 gh release upload {% raw %}"${{ needs.release-please.outputs.tag_name }}"{% endraw %} --clobber --repo {% raw %}"${{ github.repository }}"{% endraw %}
  finalize-release:
    runs-on: ubuntu-latest
    name: Publish the GitHub Release
    needs: {% if include_web %}[release-please, pypi-publish, attach-github-release, docker-publish]{% else %}[release-please, pypi-publish, attach-github-release]{% endif %}
    if: {% raw %}${{ needs.release-please.outputs.release_created == 'true' }}{% endraw %}
    permissions:
      contents: write  # IMPORTANT: Mandatory to un-draft the GitHub Release
      pull-requests: write  # IMPORTANT: Mandatory to close the phantom release PR
      actions: write  # IMPORTANT: Mandatory to re-dispatch this workflow
    steps:
      - name: Publish the draft release
        env:
          GITHUB_TOKEN: {% raw %}${{ secrets.GITHUB_TOKEN }}{% endraw %}
        run: gh release edit {% raw %}"${{ needs.release-please.outputs.tag_name }}"{% endraw %} --draft=false --repo {% raw %}"${{ github.repository }}"{% endraw %}
      - name: Reconcile the next release PR against the now-published release
        # release-please derives its commit range from the latest *published*
        # GitHub Release and ignores drafts. The release-please job above may have
        # opened the next release PR in this same run while this release was still
        # a draft, so that PR was computed with no baseline and re-lists shipped
        # commits as a phantom bump. release-please will NOT self-heal: a later
        # run with no new commits just skips, leaving the orphan PR open. So close
        # it now that the release is published, then re-dispatch. The re-dispatch
        # sees the published release and recreates a CORRECT next PR only if real
        # unreleased commits exist; otherwise it stops without reaching this job,
        # so the re-trigger is bounded to one run. (workflow_dispatch is the
        # documented exception to GITHUB_TOKEN loop-prevention, so no PAT needed.)
        env:
          GITHUB_TOKEN: {% raw %}${{ secrets.GITHUB_TOKEN }}{% endraw %}
        run: |
          pr="$(gh pr list --state open \
            --repo {% raw %}"${{ github.repository }}"{% endraw %} \
            --head {% raw %}"release-please--branches--${{ github.ref_name }}"{% endraw %} \
            --json number --jq '.[0].number // empty')"
          if [ -n "$pr" ]; then
            echo "Closing phantom release PR #$pr"
            gh pr close "$pr" --delete-branch --repo {% raw %}"${{ github.repository }}"{% endraw %}
          fi
          gh workflow run {% raw %}"${{ github.workflow }}" --ref "${{ github.ref_name }}" --repo "${{ github.repository }}"{% endraw %}
  deploy-docs:
    runs-on: ubuntu-latest
    name: Deploy Docs
    # Deploy docs inline after the release is published. The `release: published`
    # event that finalize-release emits cannot trigger a separate workflow,
    # because events fired by the GITHUB_TOKEN do not start new workflow runs
    # (the workflow_dispatch exception is why finalize-release re-dispatches
    # itself above). So docs deployment must live in this workflow as a job.
    needs: [release-please, finalize-release]
    if: {% raw %}${{ needs.release-please.outputs.release_created == 'true' }}{% endraw %}
    permissions:
      contents: write  # IMPORTANT: Mandatory for GitHub Pages
    steps:
      - name: Checkout repository
        uses: actions/checkout@9c091bb21b7c1c1d1991bb908d89e4e9dddfe3e0  # v7
        with:
          fetch-depth: 0
      - name: Set up Python
        uses: actions/setup-python@a309ff8b426b58ec0e2a45f0f869d46889d02405  # v6.2.0
        with:
          python-version-file: .python-version
      - name: Setup uv
        id: setup-uv
        uses: astral-sh/setup-uv@fac544c07dec837d0ccb6301d7b5580bf5edae39  # v8.2.0
        with:
          enable-cache: true
          cache-dependency-glob: |
            pyproject.toml
            uv.lock
      - name: Restore cache
        if: steps.setup-uv.outputs.cache-hit == 'true'
        run: echo "Cache was restored"
      - name: Build docs
        run: uv run --no-default-groups --extra all --group docs sphinx-build -b html docs docs/_build/html
      - name: Deploy to GitHub Pages
        run: |
          git config user.name "github-actions[bot]"
          git config user.email "github-actions[bot]@users.noreply.github.com"
          uv run --no-default-groups --extra all --group docs ghp-import -n -p -f docs/_build/html
