{% raw %}min_version = "2024.9.5"

[env]
PROJECT_NAME = "{{ config_root | basename }}"
_.python.venv = { path = ".venv", create = true }

[tools]
python = "{{ get_env(name='PYTHON_VERSION', default='3.10') }}"

[tasks.install]
description = "Install dependencies"
alias = "i"
run = "uv sync"

[tasks.test]
description = "Run tests"
alias = "t"
run = "uv run --locked tox run"

[tasks.style]
description = "Run style checks"
alias = "s"
run = "uv run --locked tox run -e style"

[tasks.lint]
description = "Lint the code with ruff"
alias = "l"
run = "uv run --locked ruff check"

[tasks.format]
description = "Format the code with ruff"
alias = "f"
run = "uv run --locked ruff format"

[tasks.docs-build]
description = "Build documentation"
run = "uv run --locked tox run -e docs-build"

[tasks.docs-serve]
description = "Serve documentation locally"
run = "uv run --locked tox run -e docs-server"

[tasks.prek]
description = "Run prek hooks"
alias = "pc"
run = "uv run --locked tox run -e prek"

[tasks.build]
description = "Build the package"
alias = "b"
run = "uv build"

[tasks.clean]
description = "Clean build artifacts"
run = "rm -rf dist/ build/ *.egg-info/ .tox/ .pytest_cache/ .mypy_cache/ .ruff_cache/"

[tasks.info]
description = "Print project information"
run = '''
echo "Project: $PROJECT_NAME"
echo "Python: $(python --version)"
echo "Virtual Environment: $VIRTUAL_ENV"
'''
{%- endraw %}
{%- if include_launcher %}

[tasks.package]
description = "Build a uv-bootstrap launcher executable with PyCrucible"
alias = "pkg"
run = "uv run --locked --group tool pycrucible -e . -o ./dist/{{github_repo_name}}"
{%- endif %}
{%- if include_freezer %}

[tasks.freeze]
description = "Build a self-contained offline executable with PyInstaller"
run = "uv run --locked --group tool pyinstaller {{github_repo_name}}.spec --clean --noconfirm"
{%- endif %}
{%- if include_compiler %}

[tasks.compile]
description = "Build a compiled native executable with Nuitka"
run = "uv run --locked --group tool python -m nuitka --onefile --assume-yes-for-downloads --output-dir=dist src/{{github_repo_name}}/__main__.py"
{%- endif %}
