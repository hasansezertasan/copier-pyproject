"""Module entrypoint for the project.

This is the single runnable entrypoint used by ``python -m {{github_repo_name}}``
and by every standalone-executable build (PyCrucible launcher, PyInstaller
freezer, Nuitka compiler — see ADR-007). The build tools all target this file,
so the component-selection logic lives here and nowhere else.

The enabled component with the highest precedence — CLI > GUI > TUI > web > MCP >
worker — is wired to ``main()`` at template-generation time (via the Jinja
conditionals below), so this file contains exactly one component's launch code,
not a runtime dispatch. To change the default entrypoint, re-render with a
different component enabled or edit the import/``main`` binding here directly.
With no runnable component enabled, ``main()`` exits non-zero with an
explanatory message.
"""
{%- if include_cli %}

from {{github_repo_name}}.cli import app


# The dispatchers below carry `# pragma: no cover`: invoking them launches the
# blocking component (CLI loop, GUI mainloop, server, ...), which cannot run
# under headless CI. tests/test_main.py pins the import wiring and callability.
def main() -> None:  # pragma: no cover
    """Run the CLI application."""
    app()
{%- elif include_gui %}

import sys

from {{github_repo_name}}.gui.app import main as _entry


def main() -> None:  # pragma: no cover
    """Launch the GUI application."""
    sys.exit(_entry())
{%- elif include_tui %}

import sys

from {{github_repo_name}}.tui.app import main as _entry


def main() -> None:  # pragma: no cover
    """Launch the TUI application."""
    sys.exit(_entry())
{%- elif include_web %}

from {{github_repo_name}}.web.app import main as _entry


def main() -> None:  # pragma: no cover
    """Run the web application."""
    _entry()
{%- elif include_mcp %}

from {{github_repo_name}}.mcp.app import main as _entry


def main() -> None:  # pragma: no cover
    """Run the MCP server."""
    _entry()
{%- elif include_worker %}

from {{github_repo_name}}.worker.app import main as _entry


def main() -> None:  # pragma: no cover
    """Run the message queue worker."""
    _entry()
{%- else %}

import sys


def main() -> None:
    """Fail loudly: no runnable application component is enabled.

    A standalone-executable build was produced for a project with no
    CLI/GUI/TUI/web/MCP/worker component, so there is nothing to run. Exit with
    a non-zero status and a message rather than a silent no-op, which would look
    like a broken binary to whoever launched it.
    """
    sys.exit("No runnable application component is enabled; nothing to run.")
{%- endif %}


if __name__ == "__main__":
    main()
