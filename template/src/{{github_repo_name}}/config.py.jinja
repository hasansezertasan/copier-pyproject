"""Configurations for the project."""

from __future__ import annotations

{% if include_pydantic_settings %}
from pathlib import Path

from pydantic import Field
from pydantic_settings import BaseSettings, SettingsConfigDict

from {{github_repo_name}}.__metadata__ import PROJECT_NAME


class Settings(BaseSettings):
    """Application settings using pydantic-settings.

    Settings can be configured via environment variables or .env file.
    All settings are prefixed with the project name.
    """

    model_config = SettingsConfigDict(
        env_file=".env",
        env_file_encoding="utf-8",
        env_prefix=f"{PROJECT_NAME.upper()}_",
        case_sensitive=False,
        extra="ignore",
    )

    # Example settings - customize these for your project
    debug: bool = Field(default=False, description="Enable debug mode")
    log_level: str = Field(default="INFO", description="Logging level")
    config_dir: Path = Field(
        default_factory=lambda: Path.home() / f".{PROJECT_NAME}",
        description="Configuration directory",
    )


# Global settings instance
settings = Settings()
{% endif %}
