"""Web application for the project."""
# mypy: disable-error-code="misc"

from __future__ import annotations

import platform
from importlib.metadata import Distribution, PackageNotFoundError
{% if web_framework == "fastapi" %}

from fastapi import FastAPI, HTTPException
from fastapi.responses import JSONResponse, PlainTextResponse
{% endif %}
{% if web_framework == "litestar" %}

from litestar import Litestar, get
from litestar.exceptions import HTTPException as LitestarHTTPException
{% endif %}

from {{github_repo_name}}.__metadata__ import PROJECT_NAME
from {{github_repo_name}}.core.logging_setup import logger

{% if web_framework == "fastapi" %}
app = FastAPI(title="{{github_repo_name}}")


@app.get("/version", response_class=PlainTextResponse)
def get_version() -> str:
    """Return the current version number of the project.

    Returns:
        str: The version number as a plain text string.

    Raises:
        HTTPException: If the package metadata is unavailable.
    """
    try:
        distribution = Distribution.from_name(PROJECT_NAME)
    except PackageNotFoundError:
        logger.error("Package metadata not found for %s", PROJECT_NAME)
        raise HTTPException(
            status_code=503,
            detail=f"Package metadata for '{PROJECT_NAME}' is unavailable",
        ) from None
    logger.info("HTTP GET `/version` called.")
    logger.info("Version displayed successfully.")
    return distribution.version


@app.get("/info")
def get_info() -> JSONResponse:
    """Return basic runtime information about the project.

    Returns:
        JSONResponse: A JSON response containing project and environment info.

    Raises:
        HTTPException: If the package metadata is unavailable.
    """
    try:
        distribution = Distribution.from_name(PROJECT_NAME)
    except PackageNotFoundError:
        logger.error("Package metadata not found for %s", PROJECT_NAME)
        raise HTTPException(
            status_code=503,
            detail=f"Package metadata for '{PROJECT_NAME}' is unavailable",
        ) from None
    logger.info("HTTP GET `/info` called.")
    python_version = platform.python_version()
    python_implementation = platform.python_implementation()
    payload = {
        "application_version": distribution.version,
        "python_version": python_version,
        "python_implementation": python_implementation,
        "platform": platform.system(),
    }
    logger.info("Application information displayed successfully.")
    return JSONResponse(content=payload)
{% endif %}
{% if web_framework == "litestar" %}


@get("/version", media_type="text/plain", sync_to_thread=False)
def get_version() -> str:
    """Return the current version number of the project.

    Returns:
        str: The version number as a plain text string.

    Raises:
        HTTPException: If the package metadata is unavailable.
    """
    try:
        distribution = Distribution.from_name(PROJECT_NAME)
    except PackageNotFoundError:
        logger.error("Package metadata not found for %s", PROJECT_NAME)
        raise LitestarHTTPException(
            status_code=503,
            detail=f"Package metadata for '{PROJECT_NAME}' is unavailable",
        ) from None
    logger.info("HTTP GET `/version` called.")
    logger.info("Version displayed successfully.")
    return distribution.version


@get("/info", sync_to_thread=False)
def get_info() -> dict[str, str]:
    """Return basic runtime information about the project.

    Returns:
        dict: A dictionary containing project and environment info.

    Raises:
        HTTPException: If the package metadata is unavailable.
    """
    try:
        distribution = Distribution.from_name(PROJECT_NAME)
    except PackageNotFoundError:
        logger.error("Package metadata not found for %s", PROJECT_NAME)
        raise LitestarHTTPException(
            status_code=503,
            detail=f"Package metadata for '{PROJECT_NAME}' is unavailable",
        ) from None
    logger.info("HTTP GET `/info` called.")
    python_version = platform.python_version()
    python_implementation = platform.python_implementation()
    logger.info("Application information displayed successfully.")
    return {
        "application_version": distribution.version,
        "python_version": python_version,
        "python_implementation": python_implementation,
        "platform": platform.system(),
    }


app = Litestar(route_handlers=[get_version, get_info])
{% endif %}


def main() -> None:
    """Entry point for the web application.

    Host and port default to a local-only address and can be overridden with
    the ``{PROJECT}_HOST`` / ``{PROJECT}_PORT`` environment variables.
    """
    import os  # noqa: PLC0415

    import uvicorn  # noqa: PLC0415

    host = os.environ.get(f"{PROJECT_NAME.upper()}_HOST", "127.0.0.1")
    port = int(os.environ.get(f"{PROJECT_NAME.upper()}_PORT", "8000"))
    uvicorn.run(app, host=host, port=port)
