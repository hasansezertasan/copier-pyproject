"""Top-level package for the project."""
{% if include_c_extensions %}
import logging

try:
    from {{github_repo_name}}._c_extension import ExampleExtension, fibonacci_cython
except ImportError as exc:
    # The compiled Cython extension is optional. Warn — rather than silently
    # passing or logging at debug (which is discarded before logging is
    # configured) — so a genuine build or ABI failure stays discoverable
    # instead of surfacing later as a confusing missing-name error.
    logging.getLogger(__name__).warning("C extension unavailable: %s", exc)
else:
    __all__ = ["ExampleExtension", "fibonacci_cython"]
{% endif %}
