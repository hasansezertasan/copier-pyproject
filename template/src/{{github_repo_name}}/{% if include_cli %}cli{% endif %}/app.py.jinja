"""CLI application for the project."""
# mypy: disable-error-code="misc"

from __future__ import annotations

import platform
from importlib.metadata import Distribution, PackageNotFoundError

import typer

from {{github_repo_name}}.__metadata__ import PROJECT_NAME
from {{github_repo_name}}.core.logging_setup import logger

app = typer.Typer(
    name="{{github_repo_name}}",
    no_args_is_help=True,
)


@app.command(name="version")
def show_version() -> None:
    """Show the current version number of {{github_repo_name}}.

    Show the version number:
        {{github_repo_name}} version

    Example output:
        0.1.0
    """
    try:
        distribution = Distribution.from_name(PROJECT_NAME)
    except PackageNotFoundError:
        logger.error("Package metadata not found for %s", PROJECT_NAME)
        typer.echo(
            f"Error: Package '{PROJECT_NAME}' metadata not found. "
            "Is the package installed correctly?",
            err=True,
        )
        raise typer.Exit(code=1) from None
    logger.info("Command `version` called.")
    typer.echo(distribution.version)
    logger.info("Version displayed successfully.")


@app.command()
def info() -> None:
    """Display information about the {{github_repo_name}} application.

    Show application information:
        {{github_repo_name}} info

    Example output:
        Application Version: 0.1.0
        Python Version: 3.8.20 (CPython)
        Platform: Darwin
    """
    try:
        distribution = Distribution.from_name(PROJECT_NAME)
    except PackageNotFoundError:
        logger.error("Package metadata not found for %s", PROJECT_NAME)
        typer.echo(
            f"Error: Package '{PROJECT_NAME}' metadata not found. "
            "Is the package installed correctly?",
            err=True,
        )
        raise typer.Exit(code=1) from None
    logger.info("Command `info` called.")
    python_version = platform.python_version()
    python_implementation = platform.python_implementation()
    typer.echo(f"Application Version: {distribution.version}")
    typer.echo(f"Python Version: {python_version} ({python_implementation})")
    typer.echo(f"Platform: {platform.system()}")
    logger.info("Application information displayed successfully.")

{% if include_tui %}

@app.command()
def interactive() -> None:
    """Start interactive mode for {{github_repo_name}}.

    Show application information:
        {{github_repo_name}} interactive
    """
    from {{github_repo_name}}.tui.app import main

    main()
{% endif %}
