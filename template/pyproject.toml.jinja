[project]
name = "{{github_repo_name}}"
description = "{{short_description}}"
license = "MIT"
readme = "README.md"
authors = [
  { name = "{{author_full_name}}", email = "{{author_email}}" },
]
maintainers = [
  { name = "{{author_full_name}}", email = "{{author_email}}" },
]
dynamic = ["version"]
keywords = [
{%- for keyword in package_keywords.split(",") if keyword.strip() %}
    "{{ keyword.strip() }}",
{%- endfor %}
    "command-line", "cli", "package", "metadata", "pypi", "python",
    "template", "copier", "scaffold", "boilerplate", "uv", "hatch",
    "tox", "pytest", "ruff", "mypy", "basedpyright",
    "type-hints", "typed", "modern-python",
    "ci-cd", "github-actions", "automation", "sphinx",
    "prek", "linting", "testing", "coverage", "release-automation",
{%- if include_cli %}
    "typer",
{%- endif %}
{%- if include_web %}
{%- if web_framework == "fastapi" %}
    "fastapi",
{%- endif %}
{%- if web_framework == "litestar" %}
    "litestar",
{%- endif %}
    "docker",
{%- endif %}
{%- if include_tui %}
    "textual", "tui",
{%- endif %}
{%- if include_mcp %}
    "mcp", "model-context-protocol",
{%- endif %}
{%- if include_worker %}
    "faststream", "message-queue", "{{worker_broker}}",
{%- endif %}
{%- if include_pydantic_settings %}
    "pydantic",
{%- endif %}
{%- if include_c_extensions %}
    "cython", "c-extensions", "performance",
{%- endif %}
{%- if include_launcher or include_compiler or include_freezer %}
    "standalone", "executable",
{%- endif %}
{%- if include_launcher %}
    "pycrucible", "launcher",
{%- endif %}
{%- if include_compiler %}
    "nuitka", "compiler",
{%- endif %}
{%- if include_freezer %}
    "pyinstaller", "freezer",
{%- endif %}
]
# TODO @{{github_user}}: Fill in the missing classifiers...
classifiers = [
  "Development Status :: 1 - Planning",
  "Environment :: Console",
  "Intended Audience :: Developers",
  "Intended Audience :: Information Technology",
  "Intended Audience :: System Administrators",
  "License :: OSI Approved :: MIT License",
  "Natural Language :: English",
  "Operating System :: OS Independent",
  "Programming Language :: Python :: 3 :: Only",
  "Programming Language :: Python :: 3",
  "Programming Language :: Python :: 3.10",
  "Programming Language :: Python :: 3.11",
  "Programming Language :: Python :: 3.12",
  "Programming Language :: Python :: 3.13",
  "Programming Language :: Python :: 3.14",
  "Programming Language :: Python :: Implementation :: CPython",
  "Programming Language :: Python :: Implementation :: PyPy",
  "Programming Language :: Python",
  "Topic :: Software Development :: Libraries :: Python Modules",
  "Topic :: Software Development :: Libraries",
  "Topic :: Software Development",
  "Typing :: Typed",
{% if include_cli %}
  "Topic :: Utilities",
{% endif %}
{% if include_web %}
{% if web_framework == "fastapi" %}  "Framework :: FastAPI",{% endif %}
{% if web_framework == "litestar" %}  "Framework :: Litestar",{% endif %}
  "Topic :: Internet :: WWW/HTTP :: HTTP Servers",
{% endif %}
{% if include_tui %}
  "Topic :: Terminals",
{% endif %}
{% if include_c_extensions %}
  "Topic :: Software Development :: Compilers",
{% endif %}
]
requires-python = ">=3.10"
dependencies = []

[project.optional-dependencies]
{% if include_cli %}cli = ["typer>=0.20.0"]{% endif %}
{% if include_web %}
{% if web_framework == "fastapi" %}web = ["fastapi[all]>=0.123.5"]{% endif %}
{% if web_framework == "litestar" %}web = ["litestar[standard]>=2.0.0"]{% endif %}
{% endif %}
{% if include_tui %}tui = ["textual>=0.50.0", "typing-extensions>=4.4.0"]{% endif %}
{% if include_mcp %}mcp = ["mcp>=1.0.0"]{% endif %}
{% if include_worker %}worker = ["faststream[{{ 'rabbit' if worker_broker == 'rabbitmq' else worker_broker }}]>=0.5.0", "pydantic>=2.0.0", "uvloop>=0.19.0; sys_platform != 'win32'"]{% endif %}
{% if include_pydantic_settings %}config = ["pydantic-settings>=2.0.0"]{% endif %}
all = [
{%- if include_cli %}
    "typer>=0.20.0",
{%- endif %}
{%- if include_web %}
{%- if web_framework == "fastapi" %}
    "fastapi[all]>=0.123.5",
{%- endif %}
{%- if web_framework == "litestar" %}
    "litestar[standard]>=2.0.0",
{%- endif %}
{%- endif %}
{%- if include_tui %}
    "textual>=0.50.0",
{%- endif %}
{%- if include_mcp %}
    "mcp>=1.0.0",
{%- endif %}
{%- if include_worker %}
    "faststream[{{ 'rabbit' if worker_broker == 'rabbitmq' else worker_broker }}]>=0.5.0", "pydantic>=2.0.0", "uvloop>=0.19.0; sys_platform != 'win32'",
{%- endif %}
{%- if include_pydantic_settings %}
    "pydantic-settings>=2.0.0",
{%- endif %}
]


[project.urls]
changelog = "https://github.com/{{github_user}}/{{github_repo_name}}/blob/main/CHANGELOG.md"
documentation = "https://{{github_user}}.github.io/{{github_repo_name}}"
homepage = "https://github.com/{{github_user}}/{{github_repo_name}}"
issues = "https://github.com/{{github_user}}/{{github_repo_name}}/issues"
releasenotes = "https://github.com/{{github_user}}/{{github_repo_name}}/releases"
source = "https://github.com/{{github_user}}/{{github_repo_name}}.git"

{% if include_cli or include_tui or include_web or include_mcp or include_worker %}
[project.scripts]
{% if include_cli %}{{github_repo_name}} = "{{github_repo_name}}.cli.app:app"{% endif %}
{% if include_tui %}{{github_repo_name}}-tui = "{{github_repo_name}}.tui.app:main"{% endif %}
{% if include_web %}{{github_repo_name}}-web = "{{github_repo_name}}.web.app:main"{% endif %}
{% if include_mcp %}{{github_repo_name}}-mcp = "{{github_repo_name}}.mcp.app:main"{% endif %}
{% if include_worker %}{{github_repo_name}}-worker = "{{github_repo_name}}.worker.app:main"{% endif %}
{% endif %}
{% if include_gui %}
[project.gui-scripts]
{{github_repo_name}}-gui = "{{github_repo_name}}.gui.app:main"
{% endif %}


[dependency-groups]
dev = [
  "{{github_repo_name}}[all]",
  "tox==4.31.0",
  "tox-uv==1.29.0",
  "debugpy==1.8.0",
  { include-group = "style" },
  { include-group = "test" },
]
style = [
  "actionlint-py==1.7.12.24",
  "basedpyright==1.39.8",
  "editorconfig-checker==3.6.1",
  "mypy==2.1.0",
  "pyrefly==1.1.1",
  "ruff==0.15.19",
  "slotscheck==0.20.0",
  "taplo==0.9.3",
  "ty==0.0.53",
  "typos==1.47.2",
  "validate-pyproject[all]==0.25",
  "vulture==2.16",
  "zuban==0.9.0",
  # "google-yamlfmt",
  # "shellcheck-makefile>=1.27.3",
  # "shellcheck-py>=0.10.0.1",
  # "types-PyYAML",
  # "types-setuptools",
  # "types-ujson",
  # "yamlfix>=1.18.0",
  # "yamlfmt>=1.1.1",
  # "yamllint>=1.37.1",
]
test = [
  "coverage-enable-subprocess==1.0",
  "coverage[toml]==7.11.0",
  "pytest-dependency==0.6.0",
  "pytest-mock==3.15.1",
  "pytest-rerunfailures==16.1",
  "pytest-xdist[psutil]==3.8.0",
  "pytest==8.4.2",
  "pytest-sugar",
  "pytest-asyncio>=0.23.0",
  "dirty-equals",
  "inline-snapshot",
{%- if include_worker %}
  # Integration tests start a real {{worker_broker}} in a container (ADR-008).
  "testcontainers[{{ worker_broker }}]>=4.0.0",
  # Bounds each integration test (`--timeout` in the integration tox env) so a
  # wedged container/broker fails with a traceback instead of hanging until the
  # CI job timeout kills the run with no diagnostics.
  "pytest-timeout>=2.3",
{%- endif %}
]
docs = [
    "sphinx==8.1.3",
    "shibuya==2026.5.19",
    "sphinx-autobuild==2024.10.3",  # 2025.x drops Python 3.10 (requires-python >= 3.11)
    "sphinx-copybutton==0.5.2",
    "sphinx-design==0.6.1",  # 0.7.0 drops Python 3.10 (requires-python >= 3.11)
    "sphinx-togglebutton==0.4.5",
    "sphinx-paramlinks==0.6.0",
    "auto-pytabs[sphinx]==0.5.0",
    "myst-parser==4.0.1",
    "ghp-import==2.1.0",
{%- if include_cli %}
    "sphinx-click==6.2.0",
{%- endif %}
]
tool = [
  "commitizen==4.10.0",
{%- if include_c_extensions %}
  "cython>=3.0.0",
{%- endif %}
{%- if include_profiling %}
  "py-spy>=0.4.0", "scalene>=1.5.0", "snakeviz>=2.2.0",
{%- endif %}
{%- if include_launcher %}
  "pycrucible>=0.4.6",
{%- endif %}
{%- if include_compiler %}
  "nuitka>=2.0.0",
{%- endif %}
{%- if include_freezer %}
  "pyinstaller>=6.0.0",
{%- endif %}
  # "marimo==0.15.2",
  # "inflection==0.5.1",
  # "copier==9.11.0",
]
prek = [
    "prek==0.4.3",
]


[build-system]
{% if include_c_extensions %}
requires = ["hatchling", "hatch-vcs", "cython>=3.0.0", "setuptools>=70"]
{% else %}
requires = ["hatchling", "hatch-vcs"]
{% endif %}
build-backend = "hatchling.build"


[tool.uv]
add-bounds = "exact"
cache-keys = [
  { file = "pyproject.toml" },
  { git = { commit = true, tags = true } },
]
package = true
trusted-publishing = "always"


[tool.hatch.version]
source = "vcs"
fallback-version = "0.1.0"


[tool.hatch.build]
hooks.vcs.version-file = "src/{{github_repo_name}}/_version.py"


[tool.hatch.version.raw-options]
version_scheme = "only-version"
local_scheme = "no-local-version"

[tool.hatch.metadata]
allow-direct-references = true


[tool.hatch.build.targets.sdist]
# The package uses a src layout, so the source tree lives under /src (not
# /{{github_repo_name}}); including /src ships the actual modules -- and, for
# C-extension projects, the .pyx/.pxd sources needed to compile from the sdist.
include = ["/README.md", "LICENSE", "/src", "/tests"]
{% if include_c_extensions %}

[tool.hatch.build.targets.wheel.hooks.custom]
path = "hatch_build.py"
{% endif %}

[tool.commitizen]
# Commit-authoring and message linting only. release-please owns version
# bumping, git tagging, and CHANGELOG.md (see .github/release-please-config.json),
# so the bump/tag/changelog settings are intentionally omitted here to avoid two
# tools competing over the same tags and changelog file.
name = "cz_conventional_commits"

[tool.pytest.ini_options]
# addopts = "-rXs --strict-config --strict-markers"
{%- if include_worker %}
# `integration` tests need a real {{worker_broker}} (started via testcontainers,
# Docker required), so they are deselected by default. A CLI `-m integration`
# overrides this addopts default; CI runs them in a dedicated Ubuntu-only job.
addopts = "-v --tb=short -m 'not integration'"
markers = [
  "integration: requires a real broker via testcontainers (run with -m integration)",
]
{%- else %}
addopts = "-v --tb=short"
{%- endif %}
asyncio_mode = "auto"
filterwarnings = [
  "error",
{%- if include_web and web_framework == "fastapi" %}
  # Starlette's TestClient emits a forward-compat deprecation about httpx/httpx2.
  # It is harmless for tests, so don't let `error` promote it to a failure.
  "ignore:Using `httpx` with `starlette.testclient` is deprecated:Warning",
{%- endif %}
{%- if include_worker %}
  # testcontainers applies its own deprecated @wait_container_is_ready decorator at
  # import time. The warning is internal to the library and not actionable here, so
  # don't let `error` promote it to a collection/test failure (ADR-008). The
  # integration module is imported during default collection even though its tests
  # are deselected by the `integration` marker. Scoped to the testcontainers
  # module so the same message from anywhere else still errors.
  "ignore:The @wait_container_is_ready decorator is deprecated:DeprecationWarning:testcontainers",
{%- endif %}
]
testpaths = ["tests"]
xfail_strict = true


[tool.coverage.run]
branch = true
# Match `_version.py` wherever it resolves: `src/...` in editable dev installs and
# `.../site-packages/...` when tox/CI installs the built wheel or sdist. A
# `src/**`-only pattern silently misses the installed copy and reports it at 0%.
{%- if include_worker %}
# The integration glob is directory-anchored so a future test_integration.py in
# another component (which *would* run in the default suite) stays measured.
{%- endif %}
omit = ["*/_version.py"{% if include_worker %}, "*/worker/test_integration.py"{% endif %}]
parallel = true
source_pkgs = ["{{github_repo_name}}", "tests"]


[tool.coverage.paths]
# Unify coverage data across environments. tox installs the built wheel/sdist into
# each env's site-packages, so the same source file is measured under a different
# `.tox/<env>/.../site-packages/{{github_repo_name}}` path per interpreter. Without
# remapping those back to the canonical `src/` tree, `coverage combine` keeps a
# separate copy per env and a version-gated line covered in one interpreter but not
# another is wrongly counted as missed — silently failing the `fail_under` gate.
# `tests` needs no remapping: it is never installed, so every environment measures
# it at the same repo-local path.
{{github_repo_name}} = ["src/{{github_repo_name}}", "*/site-packages/{{github_repo_name}}"]


[tool.coverage.report]
# Untestable code is excluded per site with `# pragma: no cover`, not with blanket
# patterns here: a regex matching a `def` line excludes the *whole function body*,
# so a pattern like `def main\(` would silently un-measure any future `main()`
# with real logic (and did mask the tested GUI/TUI entrypoints). Pragmas carry the
# exclusion decision next to the code it affects. See ADR-008.
exclude_lines = [
  "no cov",
  "if __name__ == .__main__.:",
  "if TYPE_CHECKING:",
]
fail_under = 99
# Patterns match both the `src/` (editable) and installed (`site-packages`)
# layouts (see [tool.coverage.run] omit).
{%- if include_worker %}
# The integration suite is deselected from the default run (it needs Docker), so
# its file is imported during collection but its test bodies are deselected and
# never run — omit it so it does not depress coverage; it runs in its own
# `integration` env (ADR-008). The integration glob is directory-anchored.
{%- endif %}
omit = ["*/_version.py"{% if include_worker %}, "*/worker/test_integration.py"{% endif %}]
show_missing = true
skip_covered = true


[tool.vulture]
# Framework-invoked handlers: Typer commands, FastAPI routes, FastStream
# lifecycle hooks, and the MCP tool dispatcher.
ignore_decorators = [
  "@app.command",
  "@app.get",
  "@app.after_startup",
  "@app.after_shutdown",
  "@server.call_tool",
{%- if include_worker %}
  # FastStream subscriber callbacks (any broker variable name) are invoked by the
  # framework, including the collector subscribers in the worker tests.
  "@*.subscriber",
{%- endif %}
]
# Public API surfaces vulture cannot see being used: ``main`` entry points are
# referenced only via pyproject scripts, ``model_config`` is consumed by
# pydantic-settings, ``logger`` is imported only by optional components, the MCP
# ``arguments`` parameter is mandated by the call_tool signature, the Textual
# names (CSS/compose/on_mount/title/BINDINGS) are invoked by the TUI framework,
# and ``pytestmark`` is consumed by pytest at collection time.
ignore_names = ["CONFIG_FILE_PATH", "logger", "main", "model_config"{% if include_mcp %}, "arguments"{% endif %}{% if include_tui %}, "CSS", "compose", "on_mount", "title", "BINDINGS"{% endif %}{% if include_worker %}, "pytestmark"{% endif %}]
min_confidence = 60
paths = ["src", "tests"]


[tool.slotscheck]
strict-imports = false


[tool.ruff]
fix = true
output-format = "full"
preview = true
show-fixes = true
src = ["src", "tests", "examples"]
target-version = "py310"
unsafe-fixes = true


[tool.ruff.analyze]
detect-string-imports = true
preview = true


[tool.ruff.format]
docstring-code-format = true
line-ending = "lf"
preview = true
skip-magic-trailing-comma = true


[tool.ruff.lint]
fixable = ["ALL"]
ignore = ["COM812", "CPY", "FIX", "TD"]
logger-objects = ["logging_setup.logger"]
preview = true
select = ["ALL"]

[tool.ruff.lint.isort]
combine-as-imports = true
# skip-magic-trailing-comma = true
split-on-trailing-comma = false

[tool.ruff.lint.flake8-copyright]
author = "{{author_full_name}} <{{author_email}}>"


[tool.ruff.lint.flake8-tidy-imports]
ban-relative-imports = "all"

{% if include_pydantic_settings %}
[tool.ruff.lint.flake8-type-checking]
# Pydantic evaluates annotations at runtime, so imports used only in model
# field annotations (e.g. `pathlib.Path`) must NOT be moved into a
# `TYPE_CHECKING` block — doing so breaks model construction.
runtime-evaluated-base-classes = [
  "pydantic.BaseModel",
  "pydantic_settings.BaseSettings",
]
{% endif %}


[tool.ruff.lint.mccabe]
max-complexity = 5


[tool.ruff.lint.pycodestyle]
ignore-overlong-task-comments = true


[tool.ruff.lint.pydocstyle]
convention = "pep257"


[tool.ruff.lint.per-file-ignores]
# Recursive glob so nested test packages (tests/cli, tests/gui, ...) are covered.
# Tests legitimately use asserts/magic values, reach into package internals, and
# don't need return-value documentation on their fixtures and helpers.
"tests/**/*.py" = ["S101", "PLR2004", "PLC2701", "DOC201"]
"examples/*.py" = ["INP001"]
# The Sphinx config is a standalone module, not part of an importable package.
"docs/conf.py" = ["INP001"]
{%- if include_c_extensions %}
# The top-level package __init__ deliberately warns at import time when the
# compiled C extension is unavailable. That import-failure handling is logic, not
# a re-export, so the preview rule RUF067 (non-empty-init-module) does not apply.
"src/{{github_repo_name}}/__init__.py" = ["RUF067"]
{%- endif %}


[tool.ruff.lint.pyupgrade]
keep-runtime-typing = true


[tool.ruff.lint.ruff]
parenthesize-tuple-in-subscript = true


[tool.mypy]
files = ["src"]
pretty = true
python_version = "3.10"
strict = true


[tool.basedpyright]
exclude = [".venv"]
include = ["src/{{github_repo_name}}"]
pythonVersion = "3.10"
venv = ".venv"
# venvPath is the directory *containing* the venv, not the venv itself; ".venv"
# here would make basedpyright look for ".venv/.venv". Use "." so both the venv
# and basedpyright's strict ruleset resolve the project's installed deps.
venvPath = "."
{%- if include_c_extensions %}
# The Cython extension ships a `.pyi` stub, but its compiled module lives in the
# build output rather than the `src/` tree basedpyright analyzes, so the
# stub-without-source check always fires on the package `__init__` import.
reportMissingModuleSource = "none"
# ruff's formatter owns formatting and keeps the wrapped warning message in
# `__init__` implicitly concatenated; basedpyright strict would otherwise flag
# it, and the line cannot be merged without tripping E501. Defer to the formatter.
reportImplicitStringConcatenation = "none"
{%- endif %}


[tool.ty.src]
include = ["src", "tests"]
respect-ignore-files = false


[tool.ty.environment]
python-version = "3.10"


[tool.ty.terminal]
error-on-warning = true


[tool.pyrefly]
python-version = "3.10"
project-includes = ["src"]
{% if include_freezer %}
[tool.typos.default.extend-identifiers]
# `datas` is the PyInstaller `Analysis(datas=...)` / `a.datas` field in
# {{github_repo_name}}.spec. typos misreads it as `data`, and its pre-commit
# hook auto-writes fixes, so allowlist it to keep the spec from being rewritten.
datas = "datas"
{% endif %}
[tool.tox]
# The ``worker`` env is intentionally omitted: it starts a broker-bound process
# and would hang/fail under ``tox run`` in CI (where no broker is available).
# The worker is covered by its pytest TestBroker suite; run it on demand with
# ``tox -e worker`` when a broker is up (e.g. inside the devcontainer).
env_list = [
    "style",
{%- if include_cli %}
    "cli",
{%- endif %}
    "3.14",
    "3.13",
    "3.12",
    "3.11",
    "3.10"
]
requires = ["tox>=4"]


[tool.tox.env_run_base]
commands = [
  [
    "coverage",
    "run",
    "--module",
    "pytest",
    "-v",
    "--tb=short",
    "--basetemp={env_tmp_dir}",
    { replace = "posargs", default = [
    ], extend = true },
  ],
]
constrain_package_deps = true
dependency_groups = ["test"]
description = "Run the tests under {base_python}"
env_tmp_dir = "{toxworkdir}/tmp/{envname}"
# Arms coverage-enable-subprocess so xdist/subprocess workers are measured too;
# `coverage run` plus `parallel = true` writes per-env data files that the CI
# `coverage combine` step merges.
set_env = { COVERAGE_PROCESS_START = "{tox_root}/pyproject.toml" }
extras = ["all"]
{% if include_c_extensions %}
# The compiled extension makes each wheel ABI-specific. Distributing as an sdist
# lets every environment compile it against its own interpreter, producing a
# correctly tagged wheel per Python version; a single shared pre-built wheel
# (e.g. cp310) cannot install under other versions (cp312, ...).
package = "sdist"
{% else %}
package = "wheel"
{% endif %}
runner = "uv-venv-runner"
use_frozen_constraints = true
wheel_build_env = ".pkg"


[tool.tox.env.style]
base_python = ["3.10"]
commands = [
  [
    "ruff",
    "check",
  ],
  [
    "ruff",
    "format",
  ],
  [
    "mypy",
    "--python-version",
    "3.10",
  ],
  [
    "mypy",
    "--python-version",
    "3.14",
  ],
  [
    "basedpyright",
  ],
  [
    "ty",
    "check",
  ],
  [
    "pyrefly",
    "check",
  ],
  [
    "zuban",
    "check",
    "src",
  ],
  [
    "vulture",
  ],
  [
    "python",
    "-m",
    "slotscheck",
    "src",
  ],
  [
    "taplo",
    "lint",
  ],
  [
    "taplo",
    "format",
  ],
  [
    "validate-pyproject",
    "pyproject.toml",
  ],
  [
    "typos",
    "--diff",
  ],
  [
    "actionlint",
  ],
  # ["yamlfmt", "."],
]
# `test` is included so the type checkers that scope tests (e.g. ty) can
# resolve pytest and other test-only imports.
dependency_groups = ["style", "test"]
description = "Run Checkers, Linters and Formatters"
runner = "uv-venv-runner"


[tool.tox.env.prek]
commands = [["prek", "run", "--all-files"]]
dependency_groups = ["prek"]
description = "Run prek hooks"
runner = "uv-venv-runner"


[tool.tox.env.docs-build]
commands = [["sphinx-build", "-b", "html", "docs", "docs/_build/html"]]
extras = ["all"]
dependency_groups = ["docs"]
description = "Build Docs"
runner = "uv-venv-runner"


[tool.tox.env.docs-server]
commands = [["sphinx-autobuild", "docs", "docs/_build/html"]]
extras = ["all"]
dependency_groups = ["docs"]
description = "Start the live-reloading docs server"
runner = "uv-venv-runner"

{%- if include_profiling %}

[tool.tox.env.profile]
commands = [
  [
    "python",
    "-c",
    "import {{github_repo_name}}; print('Profiling setup complete. Run tools manually or use profile.py script.')",
  ],
]
dependency_groups = ["tool"]
description = "Setup environment for profiling with py-spy, scalene, and cProfile"
runner = "uv-venv-runner"
{%- endif %}
{%- if include_cli %}

[tool.tox.env.cli]
commands = [["{{github_repo_name}}", "version", { replace = "posargs", extend = true }]]
description = "Run the CLI application."
runner = "uv-venv-runner"
{%- endif %}
{%- if include_worker %}

# On-demand only (not in env_list): starts a broker-bound worker, so run it with
# ``tox -e worker`` when a broker is reachable. CI relies on the pytest suite.
[tool.tox.env.worker]
commands = [["{{github_repo_name}}-worker", { replace = "posargs", extend = true }]]
description = "Run the message queue worker application."
runner = "uv-venv-runner"

# On-demand only (not in env_list): the `integration`-marked tests start a real
# {{worker_broker}} via testcontainers (Docker required), so they are excluded
# from the default suite and run explicitly with ``tox -e integration``. CI runs
# this in a dedicated Ubuntu-only job. See ADR-008. The `-m integration` here
# overrides the `-m "not integration"` default in [tool.pytest.ini_options].
[tool.tox.env.integration]
# `-W default::DeprecationWarning` overrides the strict `filterwarnings =
# ["error"]` default for this env only: real-broker tests exercise the actual
# driver and container tooling, which emit their own third-party deprecation
# warnings. We care that the round-trip works, not about library deprecation
# hygiene, so don't let those abort the run. The demotion is deliberately NOT
# module-scoped: CLI `-W` module matching is exact (not the regex the ini
# `filterwarnings` accepts), and drivers attribute warnings via `stacklevel` to
# arbitrary caller modules — e.g. the redis driver's `lib_name` deprecation
# surfaces through `redis.asyncio.connection`/faststream frames, so a scoped
# filter misses it and the run aborts. The default suite stays strict.
# `--timeout` (pytest-timeout) bounds each test so a wedged container/broker
# fails with a traceback instead of hanging until the CI job timeout.
commands = [
  [
    "pytest",
    "-m",
    "integration",
    "--timeout=300",
    "-W",
    "default::DeprecationWarning",
    "tests/worker",
    { replace = "posargs", extend = true },
  ],
]
description = "Run worker broker integration tests against a real broker."
extras = ["all"]
dependency_groups = ["test"]
runner = "uv-venv-runner"
{%- endif %}
{%- if include_launcher %}

[tool.pycrucible]
# The single runnable entrypoint (see src/{{github_repo_name}}/__main__.py),
# which runs whichever component this project enabled (CLI/GUI/TUI/web/...).
entrypoint = "src/{{github_repo_name}}/__main__.py"

[tool.pycrucible.options]
debug = false
extract_to_temp = false

[tool.pycrucible.patterns]
include = ["**/**.py", "**/*.toml", "**/*.json", "**/*.yaml", "**/*.yml"]
exclude = ["**/__pycache__/**", "**/.git/**", "**/tests/**", "**/.venv/**"]
{%- endif %}
