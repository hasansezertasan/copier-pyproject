# Copy this file to `.env` and fill in real values.
# `.env` is gitignored; never commit secrets.
{% if include_postgres %}
# --- PostgreSQL ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB={{ github_repo_name }}
{% endif %}
{%- if include_redis %}
# --- Redis / Valkey ---
# {{ redis_backend }} runs without auth by default.
# Uncomment to set a password (requires updating compose to pass it in).
# REDIS_PASSWORD=
{% endif %}
{%- if include_worker and worker_broker == 'rabbitmq' %}
# --- RabbitMQ ---
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest
{% endif %}
{%- if include_pgadmin %}
# --- pgAdmin ---
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=admin
{% endif %}
