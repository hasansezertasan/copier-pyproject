# Normalize line endings. Store everything as LF in the repo, matching the
# ruff/EditorConfig LF policy, so CRLF from Windows checkouts never leaks in.
* text=auto eol=lf

# Scripts keep platform-appropriate endings on checkout.
*.sh text eol=lf
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Explicit binaries: never normalize, never diff as text.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg text
*.woff binary
*.woff2 binary
*.pdf binary
*.zip binary
*.gz binary
*.whl binary

# GitHub Linguist overrides — keep language stats and diffs meaningful.
src/{{github_repo_name}}/_version.py linguist-generated=true
CHANGELOG.md linguist-generated=true
uv.lock linguist-generated=true
docs/** linguist-documentation
{%- if include_c_extensions %}
*.pyx linguist-language=Cython
*.pxd linguist-language=Cython
src/{{github_repo_name}}/_c_extension.c linguist-generated=true
{%- endif %}

# Keep `git archive` tarballs lean (development-only paths are excluded).
.github/ export-ignore
.devcontainer/ export-ignore
.vscode/ export-ignore
tests/ export-ignore
docs/ export-ignore
.gitattributes export-ignore
.gitignore export-ignore
.editorconfig export-ignore
