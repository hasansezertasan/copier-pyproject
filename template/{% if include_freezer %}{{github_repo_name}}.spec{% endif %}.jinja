# -*- mode: python ; coding: utf-8 -*-

# The single runnable entrypoint (see src/{{github_repo_name}}/__main__.py),
# which dispatches to the enabled component (CLI/GUI/TUI/web/...).
entry_point = "src/{{github_repo_name}}/__main__.py"

a = Analysis(
    [entry_point],
    pathex=["src"],
    binaries=[],
    datas=[],
    # TODO @{{github_user}}: add hidden imports if PyInstaller misses any.
    hiddenimports=[],
    hookspath=[],
    hooksconfig={},
    runtime_hooks=[],
    excludes=[],
    noarchive=False,
)
pyz = PYZ(a.pure)

exe = EXE(
    pyz,
    a.scripts,
    a.binaries,
    a.datas,
    [],
    name="{{github_repo_name}}",
    debug=False,
    bootloader_ignore_signals=False,
    strip=False,
    upx=True,
    upx_exclude=[],
    runtime_tmpdir=None,
    console={{ "False" if include_gui else "True" }},
    disable_windowed_traceback=False,
    argv_emulation=False,
    target_arch=None,
    codesign_identity=None,
    entitlements_file=None,
)
