"""Tests for the FastStream worker application."""

from __future__ import annotations

import pytest
from faststream.testing import TestBroker

from {{github_repo_name}}.worker.app import VersionRequest, VersionResponse, app, broker


def test_version_request_model() -> None:
    """Test VersionRequest model creation."""
    request = VersionRequest(request_id="test-123")
    assert request.request_id == "test-123"


def test_version_response_model() -> None:
    """Test VersionResponse model creation."""
    response = VersionResponse(
        request_id="test-123",
        version="1.0.0",
        python_version="3.10.0",
        platform="Linux",
    )
    assert response.request_id == "test-123"
    assert response.version == "1.0.0"
    assert response.python_version == "3.10.0"
    assert response.platform == "Linux"


def test_app_metadata() -> None:
    """Test FastStream app has correct metadata."""
    assert app.title == "{{github_repo_name}} Worker"
    assert app.description == "Message queue worker for {{github_repo_name}}"


def test_broker_exists() -> None:
    """Test broker is properly configured."""
    assert broker is not None


@pytest.mark.asyncio
async def test_handle_version_request() -> None:
    """Test version request handler produces correct response."""
    async with TestBroker(broker) as tb:
        request = VersionRequest(request_id="test-request-001")

        # The handler should process the message without errors
        await tb.publish(request, "version-requests")
