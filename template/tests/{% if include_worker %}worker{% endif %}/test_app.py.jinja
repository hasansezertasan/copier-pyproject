# The worker ``__init__`` re-exports the FastStream ``app`` object, which shadows
# the ``app`` submodule on any attribute-based import (``from ... import app``,
# ``import ...app as ...``). importlib returns the real module from sys.modules —
# the object the spies below need to patch.
worker_app = importlib.import_module("{{github_repo_name}}.worker.app")


def test_version_request_model() -> None:
    """Test VersionRequest model creation."""
    request = VersionRequest(request_id="test-123")
    assert request.request_id == "test-123"


def test_version_response_model() -> None:
    """Test VersionResponse model creation."""
    response = VersionResponse(
        request_id="test-123",
        version="1.0.0",
        python_version="3.10.0",
        platform="Linux",
    )
    assert response.request_id == "test-123"
    assert response.version == "1.0.0"
    assert response.python_version == "3.10.0"
    assert response.platform == "Linux"


def test_build_broker_forwards_url(mocker: MockerFixture) -> None:
    """``build_broker`` forwards an explicit URL to the broker constructor.

    This is the seam the integration test relies on to point the worker at a
    container-started broker (ADR-008); constructing a broker does not connect,
    so a throwaway address is safe here. Spying on the constructor pins that the
    ``url`` parameter is actually used — a fresh-instance check alone would still
    pass if the parameter were silently dropped, and that regression would only
    surface in the Docker-only integration job.
    """
    spy = mocker.spy(worker_app, "{% if worker_broker == "kafka" %}KafkaBroker{% elif worker_broker == "nats" %}NatsBroker{% elif worker_broker == "rabbitmq" %}RabbitBroker{% elif worker_broker == "redis" %}RedisBroker{% endif %}")
{%- if worker_broker == "kafka" %}
    url = "broker:9092"
{%- elif worker_broker == "nats" %}
    url = "nats://broker:4222"
{%- elif worker_broker == "rabbitmq" %}
    url = "amqp://guest:guest@broker:5672/"
{%- elif worker_broker == "redis" %}
    url = "redis://broker:6379"
{%- endif %}

    custom = build_broker(url)

    assert custom is not broker
    assert spy.call_args is not None
    assert spy.call_args.args == (url,)


def test_build_broker_env_var_fallback(
    mocker: MockerFixture, monkeypatch: pytest.MonkeyPatch
) -> None:
    """Without an explicit URL, ``build_broker`` reads the broker env var.

    The env var is the primary production configuration path; a typo in its
    name would otherwise ship silently and only surface on a real deployment.
    """
    spy = mocker.spy(worker_app, "{% if worker_broker == "kafka" %}KafkaBroker{% elif worker_broker == "nats" %}NatsBroker{% elif worker_broker == "rabbitmq" %}RabbitBroker{% elif worker_broker == "redis" %}RedisBroker{% endif %}")
{%- if worker_broker == "kafka" %}
    url = "env-host:9092"
    monkeypatch.setenv("KAFKA_BOOTSTRAP_SERVERS", url)
{%- elif worker_broker == "nats" %}
    url = "nats://env-host:4222"
    monkeypatch.setenv("NATS_URL", url)
{%- elif worker_broker == "rabbitmq" %}
    url = "amqp://guest:guest@env-host:5672/"
    monkeypatch.setenv("RABBITMQ_URL", url)
{%- elif worker_broker == "redis" %}
    url = "redis://env-host:6379"
    monkeypatch.setenv("REDIS_URL", url)
{%- endif %}

    _ = build_broker()

    assert spy.call_args is not None
    assert spy.call_args.args == (url,)


