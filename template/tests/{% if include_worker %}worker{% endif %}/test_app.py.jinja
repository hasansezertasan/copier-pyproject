def test_version_request_model() -> None:
    """Test VersionRequest model creation."""
    request = VersionRequest(request_id="test-123")
    assert request.request_id == "test-123"


def test_version_response_model() -> None:
    """Test VersionResponse model creation."""
    response = VersionResponse(
        request_id="test-123",
        version="1.0.0",
        python_version="3.10.0",
        platform="Linux",
    )
    assert response.request_id == "test-123"
    assert response.version == "1.0.0"
    assert response.python_version == "3.10.0"
    assert response.platform == "Linux"


def test_broker_exists() -> None:
    """Test the default broker is configured."""
    assert broker is not None


def test_build_broker_accepts_url() -> None:
    """``build_broker`` honors an explicit URL and yields a fresh instance.

    This is the seam the integration test relies on to point the worker at a
    container-started broker (ADR-008); constructing a broker does not connect,
    so a throwaway address is safe here.
    """
{%- if worker_broker == "kafka" %}
    custom = build_broker("broker:9092")
{%- elif worker_broker == "nats" %}
    custom = build_broker("nats://broker:4222")
{%- elif worker_broker == "rabbitmq" %}
    custom = build_broker("amqp://guest:guest@broker:5672/")
{%- elif worker_broker == "redis" %}
    custom = build_broker("redis://broker:6379")
{%- endif %}
    assert custom is not broker


