def test_version_request_model() -> None:
    """Test VersionRequest model creation."""
    request = VersionRequest(request_id="test-123")
    assert request.request_id == "test-123"


def test_version_response_model() -> None:
    """Test VersionResponse model creation."""
    response = VersionResponse(
        request_id="test-123",
        version="1.0.0",
        python_version="3.10.0",
        platform="Linux",
    )
    assert response.request_id == "test-123"
    assert response.version == "1.0.0"
    assert response.python_version == "3.10.0"
    assert response.platform == "Linux"


def test_broker_exists() -> None:
    """Test broker is properly configured."""
    assert broker is not None


