@pytest.mark.asyncio
async def test_handle_version_request() -> None:
    """A version request is consumed and a version response is published.

    Uses FastStream's in-memory test broker (no running broker required) and
    asserts on the *observable* outcome — the response delivered to a collector
    subscriber — rather than on internal handler/publisher wiring.
    """
    test_broker = build_broker()
    responses: list[dict[str, object]] = []

    @test_broker.subscriber("version-responses")
    async def collect(msg: dict[str, object]) -> None:  # noqa: RUF029
        """Capture published version responses."""
        responses.append(msg)

    async with TestBroker(test_broker):
        await test_broker.publish(
            VersionRequest(request_id="test-request-001"), "version-requests"
        )

    assert len(responses) == 1
    published = responses[0]
    assert published["request_id"] == "test-request-001"
    assert "version" in published
    assert "python_version" in published
    assert "platform" in published


@pytest.mark.asyncio
async def test_malformed_request_is_rejected() -> None:
    """A payload that fails request validation yields no response.

    Pins the worker's only externally reachable error path: FastStream validates
    the incoming message against ``VersionRequest``; a payload missing
    ``request_id`` raises a validation error (propagated by the in-memory test
    broker) and nothing is published to ``version-responses``.
    """
    test_broker = build_broker()
    responses: list[dict[str, object]] = []

    @test_broker.subscriber("version-responses")
    async def collect(msg: dict[str, object]) -> None:  # noqa: RUF029
        """Tripwire: runs only if the worker erroneously publishes a response."""
        responses.append(msg)  # pragma: no cover

    async with TestBroker(test_broker):
        with pytest.raises(ValidationError):
            await test_broker.publish({"wrong": "field"}, "version-requests")

    assert responses == []
