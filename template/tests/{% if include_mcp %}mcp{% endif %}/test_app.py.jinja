"""Tests for the MCP server."""

from __future__ import annotations

import importlib
import platform
from importlib.metadata import Distribution, PackageNotFoundError

import pytest

from {{github_repo_name}}.__metadata__ import PROJECT_NAME
from {{github_repo_name}}.mcp.app import call_tool, list_tools

# importlib (not ``from {{github_repo_name}}.mcp import app``) so a re-exported
# ``app`` attribute in ``__init__`` can never shadow the submodule the
# monkeypatch below needs to patch (the cli/web/worker packages do exactly that).
mcp_app = importlib.import_module("{{github_repo_name}}.mcp.app")


class _MissingDistribution:
    """Stub whose ``from_name`` always reports missing package metadata."""

    @staticmethod
    def from_name(name: str) -> Distribution:
        raise PackageNotFoundError(name)


@pytest.mark.asyncio
async def test_list_tools_returns_expected_tools() -> None:
    """Test that list_tools returns the expected tools."""
    tools = await list_tools()

    assert len(tools) == 2

    tool_names = {tool.name for tool in tools}
    assert "version" in tool_names
    assert "info" in tool_names


@pytest.mark.asyncio
async def test_version_tool_returns_version() -> None:
    """Test that the version tool returns the correct version."""
    result = await call_tool("version", {})

    distribution = Distribution.from_name(PROJECT_NAME)
    expected_version = distribution.version

    assert len(result) == 1
    assert result[0].type == "text"
    assert result[0].text == expected_version


@pytest.mark.asyncio
async def test_info_tool_returns_runtime_info() -> None:
    """Test that the info tool returns runtime information."""
    result = await call_tool("info", {})

    distribution = Distribution.from_name(PROJECT_NAME)

    assert len(result) == 1
    assert result[0].type == "text"

    info_text = result[0].text
    assert distribution.version in info_text
    assert platform.python_version() in info_text
    assert platform.system() in info_text


@pytest.mark.asyncio
async def test_unknown_tool_raises_error() -> None:
    """Test that calling an unknown tool raises ValueError."""
    with pytest.raises(ValueError, match="Unknown tool"):
        await call_tool("unknown_tool", {})


@pytest.mark.asyncio
async def test_tool_reports_missing_metadata(
    monkeypatch: pytest.MonkeyPatch,
) -> None:
    """Tools return an actionable error text when package metadata is missing.

    The MCP contract is a text response, not an exception: a broken install must
    surface to the MCP client as an explanatory message naming the package.
    """
    monkeypatch.setattr(mcp_app, "Distribution", _MissingDistribution)

    result = await call_tool("version", {})

    assert len(result) == 1
    assert result[0].type == "text"
    assert "metadata not found" in result[0].text
    assert PROJECT_NAME in result[0].text
